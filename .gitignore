# =============================================================================
plugins/*
!**/.keep
.specstory/

pi/operator/tasks/

# Local private data (PII/secrets/logs; encrypt before sharing)
private/
private.tar
private.tar.gz
private-merge.tar
.private.tar
private.conflicts/
# Dolos private archive metadata/artifacts are intentionally committable.
.dolos/**
!.dolos/
!.dolos/authorized_keys
!.dolos/artifacts/
!.dolos/artifacts/*.tar.gz.age
claude/.last-update-result.json
.specs/archive/pi-goal-command/
sessions/

