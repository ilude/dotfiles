# =============================================================================
# Git Configuration (machine-specific)
# =============================================================================
.gitconfig.old
.gitconfig-personal-local
.gitconfig-professional-local

# =============================================================================
# Shell Configuration (machine-specific)
# =============================================================================
.path-windows-local
.zshrc.local
*.zwc

# =============================================================================
# Secrets and Credentials
# =============================================================================
.env

# =============================================================================
# Claude Code
# =============================================================================
# Stale directory (renamed to claude/)
.claude/

# Sensitive data
claude/.credentials.json
claude/*.key
claude/*.pem
claude/*.env
claude/*secret*
claude/*password*
claude/.mcp.json
claude/policy-limits.json

# Machine-specific generated scripts
claude/chrome/chrome-native-host

# Session and state data
claude/provider-config.json
claude/toggle/
claude/CHECKPOINT
claude/.checkpoints/
claude/.session/
claude/.update.lock
claude/history.jsonl
claude/stats-cache.json
claude/sessions/

# Working directories
claude/cache/
claude/debug/
claude/downloads/
claude/file-history/
claude/ide/
claude/image-cache/
claude/paste-cache/
claude/plans/
claude/projects/
claude/session-env/
claude/shell-snapshots/
claude/tasks/
claude/teams/
claude/tmp/
claude/todos/

# Logs (keep yt/.gitkeep)
claude/logs/*
!claude/logs/yt/.gitkeep

# Plugins and telemetry
claude/plugins/
claude/statsig/
claude/telemetry/

# Specstory
claude/.specstory/

# =============================================================================
# Python
# =============================================================================
.venv/
__pycache__/
*.pyc
uv.lock
!pi/prompt-routing/uv.lock

# Prompt-router local Python/runtime artifacts
pi/prompt-routing/.venv/
pi/prompt-routing/__pycache__/
pi/prompt-routing/.pytest_cache/
pi/prompt-routing/.ruff_cache/
pi/prompt-routing/logs/

# Atomic-write leftovers from pi expertise/state writers
*.tmp-*

# =============================================================================
# Research worktrees (cloned repos for analysis)
# =============================================================================
.worktrees/

# =============================================================================
# Pi local agent state
# =============================================================================
.pi/

# =============================================================================
# Temporary and Build Files
# =============================================================================
backups/
logs/
tmpclaude-*
last-context.txt
hook-debug*.*
.last-rotation
InstallationLog.txt
*.7z

# =============================================================================
# Miscellaneous
# =============================================================================
plugins/*
!**/.keep
.specstory/

pi/operator/tasks/
