*.tmp-*

# Generated logs/state snapshots (keep source fixtures/data allowlisted where needed)
*.log
*.state.*

# Pi generated expertise/runtime state (source/config remains tracked under pi/)
pi/trust.json
pi/cache/
pi/multi-team/expertise/
pi/index/
pi/models/
pi/inspect/snapshots/
pi/**/*.jsonl
