#!/usr/bin/env python
# Claude Code status line script - cross-platform (Linux/macOS/Windows Git Bash/WSL)
# Reads JSON from stdin with model and workspace info, outputs formatted status
import json
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

# Fast path: delegate to compiled Go binary if available
def _try_go_binary() -> None:
    here = Path(os.path.realpath(__file__)).parent
    for candidate in (here / "claude-status.exe", here / "claude-status-bin"):
        if candidate.is_file():
            result = subprocess.run([str(candidate)])
            sys.exit(result.returncode)

_try_go_binary()


def run(args: list, cwd: str = None) -> str:
    try:
        r = subprocess.run(
            args, capture_output=True, text=True, cwd=cwd, timeout=5
        )
        return r.stdout.strip() if r.returncode == 0 else ""
    except Exception:
        return ""


def is_wsl() -> bool:
    if os.environ.get("WSL_DISTRO_NAME"):
        return True
    try:
        with open("/proc/version") as f:
            return "microsoft" in f.read().lower()
    except OSError:
        return False


def to_wsl_path(p: str) -> str:
    p = p.replace("\\", "/")
    m = re.match(r"^([A-Za-z]):/(.*)$", p)
    if m:
        return f"/mnt/{m.group(1).lower()}/{m.group(2)}"
    return p


def normalize_path(p: str) -> str:
    p = p.replace("\\", "/")
    p = re.sub(r"^[A-Za-z]:", "", p)       # strip C:
    p = re.sub(r"^/[a-z]/", "/", p)        # strip /c/
    p = re.sub(r"^/mnt/[a-z]/", "/", p)    # strip /mnt/c/
    return p


def get_home_pattern() -> str:
    if is_wsl():
        return f"Users/{os.environ.get('USER', '')}"
    home = os.environ.get("HOME") or os.environ.get("USERPROFILE", "")
    return normalize_path(home)


def main() -> None:
    try:
        data = json.load(sys.stdin)
        model = data.get("model", {}).get("display_name", "unknown")
        cwd = data.get("workspace", {}).get("current_dir", "")
    except Exception:
        model = "unknown"
        cwd = ""

    current_path = cwd or os.getcwd()
    git_path = to_wsl_path(current_path) if is_wsl() else current_path
    normalized = normalize_path(current_path)
    home_pat = get_home_pattern()

    git_root = run(["git", "-C", git_path, "rev-parse", "--show-toplevel"])

    if git_root:
        norm_root = normalize_path(git_root)
        basename = os.path.basename(norm_root.rstrip("/"))
        display_dir = f"~/{basename}" if norm_root.startswith(home_pat) else basename
    else:
        if normalized.startswith(home_pat):
            rel = normalized[len(home_pat):]
            display_dir = f"~{rel}" if rel else "~"
        else:
            display_dir = normalized

    branch_name = run(["git", "-C", git_path, "branch", "--show-current"])
    branch = (
        f"\033[33m[\033[34m{branch_name}\033[33m]\033[0m" if branch_name else ""
    )

    effort = "medium"
    settings_path = Path(os.path.expanduser("~")) / ".claude" / "settings.json"
    try:
        with open(settings_path) as f:
            effort = json.load(f).get("effortLevel", "medium")
    except Exception:
        pass

    claude_bin = shutil.which("claude") or "claude"
    cc_version = run([claude_bin, "--version"])
    if not cc_version:
        # Try npm global location as fallback on Windows/WSL
        npm_bin = run(["npm", "root", "-g"])
        if npm_bin:
            candidate = str(Path(npm_bin).parent / "bin" / "claude")
            cc_version = run([candidate, "--version"])
    m = re.search(r"[\d.]+", cc_version)
    cc_version = m.group(0) if m else "?"

    GREEN = "\033[32m"
    ORANGE = "\033[38;5;208m"
    DIM = "\033[2m"
    RESET = "\033[0m"

    effort_label = f"\033[37m[\033[36m{effort}\033[37m]\033[0m"
    version_label = f"{DIM}v{cc_version}{RESET}"

    if branch:
        line = (
            f"{GREEN}{display_dir}{RESET}{branch}"
            f" | {ORANGE}{model}{RESET}{effort_label} | {version_label}"
        )
    else:
        line = (
            f"{GREEN}{display_dir}{RESET}"
            f" | {ORANGE}{model}{RESET}{effort_label} | {version_label}"
        )

    sys.stdout.write(line + "\n")


if __name__ == "__main__":
    try:
        main()
    except Exception:
        sys.stdout.write("~/.claude | unknown\n")
