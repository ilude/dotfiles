#!/usr/bin/env bash

set -e

completed_steps=()
skipped_steps=()
current_step=""
install_failed=0
trap 'install_failed=$?' ERR
# shellcheck disable=SC2154
trap 'echo ""; echo "=== Install Summary ==="; for s in "${completed_steps[@]}"; do echo "  [done] $s"; done; for s in "${skipped_steps[@]}"; do echo "  [skip] $s"; done; if [[ $install_failed -ne 0 ]]; then echo "  [FAIL] $current_step"; fi' EXIT

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Self-contained platform detection (intentionally not sourcing rc.d/00-helpers.zsh)
is_windows() {
  [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ -n "$WINDIR" ]]
}

# Windows notice
if is_windows; then
    echo "=== Dotfiles Installer (Git Bash) ==="
    echo ""
    echo "For full package installation, run in PowerShell:"
    echo "  ~/.dotfiles/install.ps1"
    echo ""
    echo "Proceeding with dotbot + zsh setup..."
    echo ""
fi

current_step="XDG migration"
# Migrate from ~/.gitconfig to XDG path (~/.config/git/config)
# Remove old symlink/file so git uses the XDG location instead
if [[ -e "$HOME/.gitconfig" || -L "$HOME/.gitconfig" ]]; then
    echo "Migrating ~/.gitconfig -> ~/.config/git/config (XDG)"
    rm -f "$HOME/.gitconfig"
fi
if [[ -e "$HOME/.gitignore_global" || -L "$HOME/.gitignore_global" ]]; then
    echo "Migrating ~/.gitignore_global -> ~/.config/git/ignore (XDG)"
    rm -f "$HOME/.gitignore_global"
fi
completed_steps+=("XDG migration")

current_step=".env migration"
if [[ -f "$BASEDIR/.secrets" && ! -f "$BASEDIR/.env" ]]; then
    echo "Migrating .secrets -> .env"
    mv "$BASEDIR/.secrets" "$BASEDIR/.env"
elif [[ -f "$BASEDIR/.secrets" && -f "$BASEDIR/.env" ]]; then
    echo "Warning: both .secrets and .env exist - using .env (remove .secrets manually)"
fi
completed_steps+=(".env migration")

current_step="Dotbot symlinks"
cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"
"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "${CONFIG}" "${@}"
completed_steps+=("Dotbot symlinks")

current_step="Git filters"
if command -v jq &>/dev/null; then
    git config filter.json-sort.clean "jq --sort-keys ."
    git config filter.json-sort.smudge "cat"
    echo "git: json-sort filter configured"
else
    echo "git: jq not found, skipping json-sort filter"
fi
completed_steps+=("Git filters")

current_step="MSYS2 zsh bootstrap"
# MSYS2 zsh bootstrap: create redirect from /home/$USER to Windows home
# This fixes the HOME mismatch between Git Bash and MSYS2's zsh
if is_windows && [[ -d "/home/$USER" ]]; then
    target="/home/$USER/.zshrc"
    source="${BASEDIR}/zsh/zshrc-msys2-bootstrap"
    if [[ -f "$target" ]] && cmp -s "$source" "$target"; then
        echo "MSYS2 bootstrap: already correct"
    else
        echo "Creating MSYS2 zsh bootstrap..."
        cp "$source" "$target"
        echo "  Created $target"
    fi
fi
completed_steps+=("MSYS2 zsh bootstrap")

# Skip GUI tools on headless Linux servers.
# Detection is machine-level (not shell-level) so a remote terminal on a GUI
# workstation -- e.g. VS Code Remote SSH with no DISPLAY -- still installs
# GUI-adjacent tooling. Order:
#   1. DOTFILES_HEADLESS=1 / DOTFILES_GUI=1 -- explicit override (escape hatch)
#   2. macOS, Windows, WSL -- never headless
#   3. Shell already has a graphical session ($DISPLAY/$WAYLAND_DISPLAY) -- GUI
#   4. systemd default target is graphical.target -- GUI workstation
#   5. Xorg/Xwayland binary present -- GUI capable
#   6. Otherwise -- treat as headless
HEADLESS=
if [[ -n "${DOTFILES_HEADLESS:-}" ]]; then
    HEADLESS=1
elif [[ -n "${DOTFILES_GUI:-}" ]]; then
    HEADLESS=
elif [[ "$OSTYPE" == "darwin"* ]] || is_windows || [[ -n "$WSL_DISTRO_NAME" ]]; then
    HEADLESS=
elif [[ -n "$DISPLAY" || -n "$WAYLAND_DISPLAY" ]]; then
    HEADLESS=
elif command -v systemctl &>/dev/null && [[ "$(systemctl get-default 2>/dev/null)" == "graphical.target" ]]; then
    HEADLESS=
elif command -v Xorg &>/dev/null || command -v Xwayland &>/dev/null; then
    HEADLESS=
else
    HEADLESS=1
fi
if [[ -n "$HEADLESS" ]]; then
    echo "Headless server detected - skipping GUI tool setup"
fi

current_step="Git SSH setup"
"${BASEDIR}/scripts/git-ssh-setup"
completed_steps+=("Git SSH setup")

current_step="Zsh setup"
"${BASEDIR}/scripts/zsh-setup"
completed_steps+=("Zsh setup")

current_step="uv install"
# Install uv (Python package manager)
if ! command -v uv &>/dev/null; then
    echo "Installing uv..."
    curl -LsSf https://astral.sh/uv/install.sh | sh
else
    echo "uv: already installed, checking for updates..."
    uv self update
fi
completed_steps+=("uv install")

# Harden uv resolutions for repo install-time tooling: delay newly-uploaded
# packages, keep first-index dependency-confusion protection explicit, ignore
# development-only Git/URL/path sources, and avoid arbitrary sdist builds.
export UV_EXCLUDE_NEWER="${UV_EXCLUDE_NEWER:-3 days}"
export UV_INDEX_STRATEGY="${UV_INDEX_STRATEGY:-first-index}"
export UV_NO_SOURCES="${UV_NO_SOURCES:-true}"
export UV_NO_BUILD="${UV_NO_BUILD:-true}"

current_step="Python shim"
# Install Python 3.14 via uv and shim 'python' into ~/.local/bin
# Hooks use bare 'python' (not python3) cross-platform; this ensures it resolves.
if command -v uv &>/dev/null; then
    uv python install 3.14 2>/dev/null || true
    py314="$(uv python find --system 3.14 2>/dev/null || true)"
    if [[ -n "$py314" ]]; then
        mkdir -p "$HOME/.local/bin"
        ln -sf "$py314" "$HOME/.local/bin/python"
        echo "python: shimmed to $py314"
    else
        echo "Warning: could not locate Python 3.14 after install"
    fi
else
    echo "Warning: uv not found, skipping Python shim"
fi
completed_steps+=("Python shim")

current_step="Python dev tools"
if command -v uv &>/dev/null; then
    # Install ruff globally via uv tool
    if command -v ruff &>/dev/null; then
        echo "ruff: already installed"
    else
        echo "Installing ruff..."
        uv tool install --exclude-newer "${UV_EXCLUDE_NEWER}" --index-strategy "${UV_INDEX_STRATEGY}" --no-sources --no-build ruff
    fi
    # Install lizard (cyclomatic complexity analyzer) globally via uv tool
    if command -v lizard &>/dev/null; then
        echo "lizard: already installed"
    else
        echo "Installing lizard..."
        uv tool install --exclude-newer "${UV_EXCLUDE_NEWER}" --index-strategy "${UV_INDEX_STRATEGY}" --no-sources --no-build lizard
    fi
    # Install detect-secrets for /commit secret scanning
    if command -v detect-secrets-hook &>/dev/null; then
        echo "detect-secrets: already installed"
    else
        echo "Installing detect-secrets..."
        uv tool install --exclude-newer "${UV_EXCLUDE_NEWER}" --index-strategy "${UV_INDEX_STRATEGY}" --no-sources --no-build detect-secrets
    fi
fi
completed_steps+=("Python dev tools")

current_step="Claude Code hook dependencies"
# Hooks use bare python (not uv) to avoid console window flashing on Windows.
# Since settings.json is shared cross-platform, Linux also needs these in system Python.
# Map: pip package name -> Python import name
hook_deps=("pyyaml:yaml" "tree-sitter:tree_sitter" "tree-sitter-bash:tree_sitter_bash")
# Use the shimmed python, fall back to python3
_py="$(command -v python 2>/dev/null || command -v python3 2>/dev/null || true)"
if [[ -z "$_py" ]]; then
    echo "Warning: no python found, skipping hook deps"
else
    for entry in "${hook_deps[@]}"; do
        dep="${entry%%:*}"
        module="${entry##*:}"
        if "$_py" -c "import ${module}" 2>/dev/null; then
            echo "${dep}: already installed"
        else
            echo "Installing ${dep}..."
            uv pip install --python "$_py" --break-system-packages --exclude-newer "${UV_EXCLUDE_NEWER}" --index-strategy "${UV_INDEX_STRATEGY}" --no-build "${dep}" 2>/dev/null || "$_py" -m pip install --break-system-packages "${dep}" 2>/dev/null || echo "Warning: failed to install ${dep}"
        fi
    done
fi
completed_steps+=("Claude Code hook dependencies")

current_step="fnm install"
# fnm installs to ~/.local/share/fnm; ensure it's on PATH for detection
[[ -d "$HOME/.local/share/fnm" ]] && export PATH="$HOME/.local/share/fnm:$PATH"
if command -v fnm &>/dev/null; then
    echo "fnm: already installed"
else
    echo "Installing fnm..."
    curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell
    export PATH="$HOME/.local/share/fnm:$PATH"
fi
# Install LTS Node via fnm if node is missing or too old (need 20+ for Pi)
eval "$(fnm env --shell bash)"
_node_major="$(node --version 2>/dev/null | sed 's/^v//' | cut -d. -f1)"
if [[ -z "$_node_major" || "$_node_major" -lt 20 ]]; then
    fnm install --lts
    fnm default lts-latest
    echo "node: installed $(fnm exec --using=default node --version) via fnm"
else
    echo "node: $(node --version) (>= 20, OK)"
fi
unset _node_major
completed_steps+=("fnm install")

current_step="Homebrew packages"
if [[ "$OSTYPE" == "darwin"* ]] && command -v brew &>/dev/null; then
    echo "Installing Homebrew packages..."
    if ! brew bundle --file="${BASEDIR}/Brewfile"; then
        echo "Warning: some Homebrew packages failed to install"
    fi
fi
completed_steps+=("Homebrew packages")

current_step="Bun install"
# Bun is the JS runtime for pi web-fetch deps and other JS tooling.
# Windows installs bun via install.ps1; Linux/macOS install it here.
if ! is_windows; then
    # Check PATH and ~/.bun/bin directly (bun may not be on PATH in bash sessions)
    if command -v bun &>/dev/null; then
        echo "bun: already installed ($(bun --version 2>/dev/null))"
    elif [[ -x "$HOME/.bun/bin/bun" ]]; then
        echo "bun: already installed ($("$HOME/.bun/bin/bun" --version 2>/dev/null))"
        export BUN_INSTALL="$HOME/.bun"
        export PATH="$BUN_INSTALL/bin:$PATH"
    else
        echo "Installing bun..."
        curl -fsSL https://bun.sh/install | bash
        export BUN_INSTALL="$HOME/.bun"
        export PATH="$BUN_INSTALL/bin:$PATH"
    fi
    # Remove legacy bun->node symlink. It used to redirect #!/usr/bin/env node
    # shebangs to bun, but it shadows real Node.js (required by pnpm and other
    # node CLIs). Real node comes from fnm / Brewfile / winget instead.
    if [[ -L "$HOME/.bun/bin/node" ]] && [[ "$(readlink "$HOME/.bun/bin/node")" == *bun* ]]; then
        rm -f "$HOME/.bun/bin/node"
        echo "bun: removed legacy node symlink"
    fi
fi
completed_steps+=("Bun install")

current_step="Claude Code install"
if [[ "$OSTYPE" == "darwin"* ]]; then
    if command -v brew &>/dev/null; then
        if brew list --cask claude-code &>/dev/null || brew list --cask claude-code@latest &>/dev/null; then
            echo "claude-code: already installed via Homebrew ($(claude --version 2>/dev/null || echo 'unknown'))"
        else
            echo "Installing claude-code via Homebrew..."
            if ! brew install --cask claude-code; then
                echo "Warning: failed to install claude-code via Homebrew"
            fi
        fi

        if [[ -L "$HOME/.bun/bin/claude" || -f "$HOME/.bun/bin/claude" ]]; then
            echo "Removing legacy bun-installed claude..."
            if command -v bun &>/dev/null; then
                bun uninstall -g @anthropic-ai/claude-code &>/dev/null || true
            fi
            rm -f "$HOME/.bun/bin/claude"
        fi
    else
        echo "claude-code: Homebrew not found, skipping"
    fi
else
    if command -v curl &>/dev/null; then
        echo "Installing/updating claude-code via native installer..."
        if ! curl -fsSL https://claude.ai/install.sh | bash; then
            echo "Warning: failed to install claude-code via native installer"
        fi
    else
        echo "claude-code: curl not found, skipping"
    fi
fi
completed_steps+=("Claude Code install")

current_step="just install"
if command -v just &>/dev/null; then
    echo "just: already installed"
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    if command -v apt-get &>/dev/null; then
        echo "Installing just..."
        curl -fsSL https://just.systems/install.sh | bash -s -- --to ~/.local/bin
    elif command -v cargo &>/dev/null; then
        cargo install just
    else
        echo "Warning: cannot install just (no apt-get or cargo)"
    fi
fi
completed_steps+=("just install")

current_step="Pi coding agent install"
# Pi installs via pnpm on all platforms. pnpm's strict resolver pins transitive
# pi packages cleanly; bun's looser resolution let pi-agent-core/pi-ai/pi-tui
# drift to newer patch versions even when pi-coding-agent itself was pinned.

# Ensure PNPM_HOME is set before bootstrap so the installer knows where to put
# binaries, and so SHELL=/dev/null can suppress rc-file appends.
if [[ -z "${PNPM_HOME:-}" ]]; then
    if [[ "$OSTYPE" == "darwin"* ]]; then
        export PNPM_HOME="$HOME/Library/pnpm"
    else
        export PNPM_HOME="$HOME/.local/share/pnpm"
    fi
fi

case ":$PATH:" in
    *":$PNPM_HOME/bin:"*) ;;
    *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac

if ! command -v pnpm &>/dev/null; then
    echo "Bootstrapping pnpm via official installer..."
    curl -fsSL https://get.pnpm.io/install.sh | PNPM_HOME="$PNPM_HOME" SHELL=/bin/bash sh -
fi

if command -v pnpm &>/dev/null; then
    # Harden pnpm installs against common supply-chain attacks. These global
    # defaults require install-script review, delay newly-published packages,
    # and block exotic transitive dependency sources.
    pnpm config set --global minimumReleaseAge 4320 >/dev/null || echo "Warning: failed to set pnpm minimumReleaseAge"
    pnpm config set --global blockExoticSubdeps true >/dev/null || echo "Warning: failed to set pnpm blockExoticSubdeps"
    pnpm config set --global strictDepBuilds true >/dev/null || echo "Warning: failed to set pnpm strictDepBuilds"

    # Remove conflicting/legacy installs BEFORE running pnpm add. pnpm refuses to
    # install when another package owns the same global "pi" bin (e.g. the legacy
    # @mariozechner/pi-coding-agent), so cleanup must precede the install.
    if [[ "$OSTYPE" == "darwin"* ]] && command -v brew &>/dev/null && brew list pi-coding-agent &>/dev/null; then
        echo "Removing Homebrew-installed pi-coding-agent to prefer pnpm-managed updates..."
        brew uninstall pi-coding-agent || echo "Warning: failed to uninstall Homebrew pi-coding-agent"
    fi

    if pnpm list -g --depth -1 2>/dev/null | grep -q '@mariozechner/pi-coding-agent'; then
        echo "Removing legacy pnpm-installed @mariozechner/pi-coding-agent..."
        pnpm remove -g @mariozechner/pi-coding-agent &>/dev/null || true
    fi

    if pnpm list -g --depth -1 2>/dev/null | grep -q '^birdclaw'; then
        echo "Removing pnpm-installed birdclaw and its global dependencies..."
        pnpm remove -g birdclaw &>/dev/null || true
        rm -f "$PNPM_HOME/birdclaw" "$PNPM_HOME/birdclaw.CMD" "$PNPM_HOME/birdclaw.ps1"
    fi

    if command -v bun &>/dev/null && [[ -L "$HOME/.bun/bin/pi" || -f "$HOME/.bun/bin/pi" ]]; then
        echo "Removing legacy bun-installed pi-coding-agent..."
        bun uninstall -g @earendil-works/pi-coding-agent &>/dev/null || true
        bun uninstall -g @mariozechner/pi-coding-agent &>/dev/null || true
        rm -f "$HOME/.bun/bin/pi"
    fi

    if command -v npm &>/dev/null && { npm list -g @earendil-works/pi-coding-agent &>/dev/null || npm list -g @mariozechner/pi-coding-agent &>/dev/null; }; then
        echo "Removing legacy npm-installed pi-coding-agent..."
        npm uninstall -g @earendil-works/pi-coding-agent &>/dev/null || true
        npm uninstall -g @mariozechner/pi-coding-agent &>/dev/null || true
    fi

    echo "Installing/updating pi-coding-agent via pnpm..."
    pnpm add -g --allow-build=koffi --allow-build=protobufjs \
        @earendil-works/pi-coding-agent \
        @earendil-works/pi-agent-core \
        @earendil-works/pi-ai \
        @earendil-works/pi-tui

    pi_markdown_patch="${BASEDIR}/install.d/50-pi-markdown-code-fence-fix.py"
    if [[ -f "$pi_markdown_patch" ]]; then
        if command -v python3 >/dev/null 2>&1; then
            python3 "$pi_markdown_patch" || echo "Warning: Pi markdown code fence patch failed"
        elif command -v python >/dev/null 2>&1; then
            python "$pi_markdown_patch" || echo "Warning: Pi markdown code fence patch failed"
        else
            echo "Warning: python unavailable; skipping Pi markdown code fence patch"
        fi
    fi
else
    echo "Warning: pnpm unavailable; skipping pi-coding-agent install"
fi
completed_steps+=("Pi coding agent install")

current_step="pi extension deps link"
"${BASEDIR}/scripts/pi-deps-link-setup"
completed_steps+=("pi extension deps link")

current_step="pi web-fetch deps"
WEB_FETCH_DIR="${BASEDIR}/pi/extensions/web-fetch"
if [[ -d "$WEB_FETCH_DIR" ]]; then
    if [[ ! -d "$WEB_FETCH_DIR/node_modules" ]]; then
        echo "Installing pi web-fetch dependencies..."
        if command -v bun &>/dev/null; then
            bun install --cwd "$WEB_FETCH_DIR"
        elif command -v pnpm &>/dev/null; then
            pnpm install --dir "$WEB_FETCH_DIR"
        else
            echo "Warning: bun and pnpm both unavailable; skipping pi web-fetch deps"
        fi
    else
        echo "pi web-fetch deps: already installed"
    fi
fi
completed_steps+=("pi web-fetch deps")

current_step="pi agent directory link"
"${BASEDIR}/scripts/pi-link-setup"
completed_steps+=("pi agent directory link")

current_step="GUI tool setup"
if [[ -z "$HEADLESS" ]]; then
    "${BASEDIR}/scripts/claude-link-setup"
    "${BASEDIR}/scripts/opencode-link-setup"
    "${BASEDIR}/scripts/claude-mcp-setup"
    "${BASEDIR}/scripts/claude-plugins-setup"
    "${BASEDIR}/scripts/copilot-link-setup"
    completed_steps+=("GUI tool setup")
else
    skipped_steps+=("GUI tool setup (headless)")
fi

current_step="claude-status binary"
# Not gated by HEADLESS: claude-status is a terminal statusline used by Claude
# Code on any host (including headless servers). Docker absence is handled
# below by falling back to the Python implementation.
if is_windows; then
    _status_bin="claude-status.exe"
else
    _status_bin="claude-status-bin"
fi
if [[ -f "$HOME/.claude/$_status_bin" ]]; then
    echo "claude-status binary: already built"
elif command -v docker &>/dev/null; then
    echo "Building claude-status binary..."
    if ! bash "${BASEDIR}/claude/claude-status-go/build.sh"; then
        echo "Warning: claude-status build failed (Python fallback active)"
    fi
else
    echo "claude-status: docker not found, skipping (Python fallback active)"
fi
completed_steps+=("claude-status binary")

current_step="Credential lockdown"
# Lock down sensitive credential files
[[ -f "$HOME/.claude/.credentials.json" ]] && chmod 600 "$HOME/.claude/.credentials.json"
completed_steps+=("Credential lockdown")

current_step="install.d hooks"
# Run drop-in install.d hooks in lexical order. Bash installs run *.sh plus
# common *.py hooks; move a hook to install.d/disabled/ to turn it off. Each
# script must be idempotent; a nonzero exit is treated as a soft failure so one
# broken hook does not brick the whole install.
INSTALL_D="${BASEDIR}/install.d"
if [[ -d "$INSTALL_D" ]]; then
    export DOTFILES_ROOT="$BASEDIR"
    shopt -s nullglob
    hooks=("$INSTALL_D"/*.sh "$INSTALL_D"/*.py)
    if ((${#hooks[@]} > 0)); then
        IFS=$'\n' read -r -d '' -a hooks < <(printf '%s\n' "${hooks[@]}" | sort && printf '\0')
        for hook in "${hooks[@]}"; do
            [[ -f "$hook" ]] || continue
            hook_name="$(basename "$hook")"
            echo "Running install.d/$hook_name"
            case "$hook" in
                *.sh) runner=(bash "$hook") ;;
                *.py)
                    if command -v python3 >/dev/null 2>&1; then
                        runner=(python3 "$hook")
                    elif command -v python >/dev/null 2>&1; then
                        runner=(python "$hook")
                    else
                        echo "Warning: python unavailable; skipping install.d/$hook_name" >&2
                        continue
                    fi
                    ;;
                *) continue ;;
            esac
            if ! "${runner[@]}"; then
                echo "Warning: install.d/$hook_name failed; continuing" >&2
            fi
        done
    fi
    shopt -u nullglob
fi
completed_steps+=("install.d hooks")
