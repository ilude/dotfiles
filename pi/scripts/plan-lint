#!/usr/bin/env python
"""Validate durable plan state and optional /do-it report claims."""

from __future__ import annotations

import argparse
import re
import subprocess
from dataclasses import dataclass
from pathlib import Path

TASK_RE = re.compile(r"^- \[(?P<checked>[ xX])\] (?P<name>T\d+):(?P<body>.*)$")
DONE_RE = re.compile(r"\bdone:\s*`?(?P<commit>[0-9a-fA-F]{7,40})`?\b")
IN_PROGRESS_RE = re.compile(r"\bin-progress:\s*(?P<next>.+?)\s*$")
STATE_FIELD_RE = re.compile(r"^- \*\*(?P<name>[^*]+):\*\*\s*(?P<value>.*)$")
REPORT_FIRST_RE = re.compile(r"^(?P<state>COMPLETE|CHECKPOINT|BLOCKED):")
REPORT_LAST_RE = re.compile(r"^FINAL STATUS: (?P<state>COMPLETE|CHECKPOINT|BLOCKED)\b")


@dataclass(frozen=True)
class Violation:
    code: str
    line: int
    message: str


def git_root(plan_path: Path) -> Path | None:
    result = subprocess.run(
        ["git", "-C", str(plan_path.parent), "rev-parse", "--show-toplevel"],
        capture_output=True,
        check=False,
        text=True,
    )
    if result.returncode != 0:
        return None
    return Path(result.stdout.strip())


def commit_exists(repo: Path, commit: str) -> bool:
    result = subprocess.run(
        ["git", "-C", str(repo), "cat-file", "-e", f"{commit}^{{commit}}"],
        capture_output=True,
        check=False,
        text=True,
    )
    return result.returncode == 0


def state_fields(lines: list[str]) -> dict[str, tuple[str, int]]:
    fields: dict[str, tuple[str, int]] = {}
    in_state = False
    for number, line in enumerate(lines, 1):
        if line.strip() == "### State":
            in_state = True
            continue
        if in_state and line.startswith("### "):
            break
        if not in_state:
            continue
        match = STATE_FIELD_RE.match(line)
        if match:
            fields[match.group("name").strip().lower()] = (
                match.group("value").strip(),
                number,
            )
    return fields


def expected_report_state(
    plan_path: Path,
    fields: dict[str, tuple[str, int]],
    unchecked_tasks: int,
) -> str:
    classification = fields.get("state", fields.get("classification", ("", 0)))[0].lower()
    blocker = fields.get("current blocker", ("", 0))[0].lower()
    archive = fields.get("archive", ("", 0))[0]
    is_complete = unchecked_tasks == 0 and (
        classification.startswith("complete") or classification.startswith("completed")
    )
    is_archived = "archive" in plan_path.parts or archive.startswith(".specs/archive/")
    if is_complete and is_archived:
        return "COMPLETE"
    if classification.startswith("blocked") and blocker not in {"", "none"}:
        return "BLOCKED"
    return "CHECKPOINT"


def lint_report(report_path: Path, expected: str) -> list[Violation]:
    lines = report_path.read_text(encoding="utf-8").splitlines()
    nonempty = [(number, line.strip()) for number, line in enumerate(lines, 1) if line.strip()]
    if not nonempty:
        return [Violation("report-state", 1, "report is empty")]
    first_number, first = nonempty[0]
    last_number, last = nonempty[-1]
    first_match = REPORT_FIRST_RE.match(first)
    last_match = REPORT_LAST_RE.match(last)
    violations: list[Violation] = []
    if not first_match:
        violations.append(
            Violation("report-state", first_number, "first line has no recognized report state")
        )
    if not last_match:
        violations.append(
            Violation("report-state", last_number, "last line has no recognized final state")
        )
    if first_match and first_match.group("state") != expected:
        violations.append(
            Violation(
                "report-state",
                first_number,
                f"report claims {first_match.group('state')} but plan permits {expected}",
            )
        )
    if last_match and last_match.group("state") != expected:
        violations.append(
            Violation(
                "report-state",
                last_number,
                f"final report claims {last_match.group('state')} but plan permits {expected}",
            )
        )
    return violations


def lint_plan(
    plan_path: Path, repo: Path, report_path: Path | None = None
) -> tuple[list[Violation], str]:
    lines = plan_path.read_text(encoding="utf-8").splitlines()
    violations: list[Violation] = []
    unchecked_tasks = 0

    for number, line in enumerate(lines, 1):
        match = TASK_RE.match(line)
        if not match:
            continue
        checked = match.group("checked").lower() == "x"
        body = match.group("body").strip()
        if checked:
            done = DONE_RE.search(body)
            if not done:
                violations.append(
                    Violation(
                        "checked-task-commit",
                        number,
                        f"{match.group('name')} is checked without done: <commit>",
                    )
                )
            elif not commit_exists(repo, done.group("commit")):
                violations.append(
                    Violation(
                        "checked-task-commit",
                        number,
                        f"{match.group('name')} references missing commit {done.group('commit')}",
                    )
                )
        else:
            unchecked_tasks += 1
            if "in-progress:" in body:
                in_progress = IN_PROGRESS_RE.search(body)
                if not in_progress or not in_progress.group("next").strip():
                    violations.append(
                        Violation(
                            "in-progress-next-step",
                            number,
                            f"{match.group('name')} is in progress without a next step",
                        )
                    )

    fields = state_fields(lines)
    classification, classification_line = fields.get("state", fields.get("classification", ("", 1)))
    blocker, blocker_line = fields.get("current blocker", ("", classification_line))
    classification_lower = classification.lower()
    blocker_lower = blocker.lower()
    is_blocked = classification_lower.startswith("blocked")
    blocker_is_none = blocker_lower in {"", "none"}
    if is_blocked and blocker_is_none:
        violations.append(
            Violation(
                "state-checklist-mismatch",
                blocker_line,
                "blocked classification requires a current blocker",
            )
        )
    if not is_blocked and not blocker_is_none:
        violations.append(
            Violation(
                "state-checklist-mismatch",
                blocker_line,
                "current blocker requires a blocked classification",
            )
        )
    if (
        classification_lower.startswith("complete") or classification_lower.startswith("completed")
    ) and unchecked_tasks:
        violations.append(
            Violation(
                "state-checklist-mismatch",
                classification_line,
                f"completed state has {unchecked_tasks} unchecked top-level task(s)",
            )
        )

    report_state = expected_report_state(plan_path, fields, unchecked_tasks)
    if report_path is not None:
        violations.extend(lint_report(report_path, report_state))
    return violations, report_state


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("plan", type=Path, help="Plan file ending in plan.md")
    parser.add_argument("--report", type=Path, help="Optional /do-it report file to validate")
    parser.add_argument("--repo", type=Path, help="Git repository root (auto-detected by default)")
    args = parser.parse_args()

    plan_path = args.plan.resolve()
    if plan_path.name != "plan.md" or not plan_path.is_file():
        parser.error("plan must be an existing file ending in plan.md")
    repo = args.repo.resolve() if args.repo else git_root(plan_path)
    if repo is None:
        print(f"PLAN_LINT_FAILED {plan_path}")
        print("git-repository:1: plan is not inside a Git worktree")
        return 1

    violations, report_state = lint_plan(
        plan_path,
        repo,
        args.report.resolve() if args.report else None,
    )
    if violations:
        print(f"PLAN_LINT_FAILED {plan_path}")
        for violation in violations:
            print(f"{violation.code}:{violation.line}: {violation.message}")
        return 1
    print(f"PLAN_LINT_OK {plan_path}")
    print(f"report_state={report_state}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
