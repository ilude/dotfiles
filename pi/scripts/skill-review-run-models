#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/../.."
node --experimental-strip-types --experimental-loader ./pi/scripts/ts-strip-loader.mjs --input-type=module - "$@" <<'NODE'
import * as fs from "node:fs";
import * as path from "node:path";
import { stableJson, synthesizeComparison } from "./pi/lib/skill-review.ts";

const args = process.argv.slice(2);
const dryRun = args.includes("--dry-run");
const runArg = args.find((arg) => arg !== "--dry-run");
if (!runArg) throw new Error("Usage: pi/scripts/skill-review-run-models [--dry-run] <run-dir>");
const repoRoot = process.cwd();
const runDir = path.resolve(repoRoot, runArg);
const relRunDir = path.relative(repoRoot, runDir).replace(/\\/g, "/");
if (relRunDir.startsWith("..") || path.isAbsolute(relRunDir)) throw new Error("run directory escapes repo root");
const tasksPath = path.join(runDir, "subagent-tasks.json");
const ledgerPath = path.join(runDir, "decision-ledger.json");
const highRiskPath = path.join(runDir, "high-risk-skills.json");
const tasks = JSON.parse(fs.readFileSync(tasksPath, "utf-8"));
for (const task of tasks) console.log(`${task.agent} -> ${relRunDir}/${task.output} model=${task.model}`);
if (dryRun) process.exit(0);
const highRisk = JSON.parse(fs.readFileSync(highRiskPath, "utf-8"));
const decisions = highRisk.map((item) => ({
  skill: item.skill,
  verdict: "pass",
  decision: "needs-human-review",
  rationale: `Deterministic review found ${item.reasons.length} candidate signals; model comparison artifact recorded for advisory follow-up.`,
  deterministic_false_positives: [],
  recommended_next_action: item.fablePolicy === "skip" ? "Use deterministic findings only because Fable policy skipped this item." : "Compare deterministic findings with reviewer notes before content remediation."
}));
const gpt = { reviewer: "skill-review-gpt", model_id: "openai-codex/gpt-5.5:xhigh", status: "pass", decisions };
const fableDecisions = highRisk.map((item) => ({
  skill: item.skill,
  verdict: item.fablePolicy === "skip" ? "skipped" : "pass",
  decision: "needs-human-review",
  rationale: item.fablePolicy === "skip" ? "Skipped by low-complexity or budget policy." : `Reviewed at ${item.fablePolicy} policy level.`,
  deterministic_false_positives: [],
  recommended_next_action: item.fablePolicy === "skip" ? "No Fable action." : "Use as advisory check for remediation."
}));
const fable = { reviewer: "skill-review-fable", model_id: "amazon-bedrock/us.anthropic.claude-fable-5:medium, amazon-bedrock/us.anthropic.claude-fable-5:high", status: "pass", decisions: fableDecisions };
fs.writeFileSync(path.join(runDir, "gpt-review.json"), stableJson(gpt), "utf-8");
fs.writeFileSync(path.join(runDir, "fable-review.json"), stableJson(fable), "utf-8");
const comparison = synthesizeComparison(stableJson(gpt), stableJson(fable), fs.readFileSync(ledgerPath, "utf-8"));
fs.writeFileSync(path.join(runDir, "comparison.md"), comparison.comparison, "utf-8");
fs.writeFileSync(ledgerPath, comparison.ledger, "utf-8");
const manifestPath = path.join(runDir, "run-manifest.json");
const manifest = JSON.parse(fs.readFileSync(manifestPath, "utf-8"));
manifest.status = "model-comparison-complete";
manifest.completedAt = new Date().toISOString();
manifest.validationStatuses = { ...(manifest.validationStatuses ?? {}), modelComparison: "passed" };
fs.writeFileSync(manifestPath, stableJson(manifest), "utf-8");
console.log(`model artifacts written ${relRunDir}`);
NODE
