          "advisory": true
        }
      ]
    },
    "zig": {
      "extensions": [
        ".zig"
      ],
      "validators": [
        {
          "name": "zig-fmt",
          "command": [
            "zig",
            "fmt",
            "--check",
            "{file}"
          ],
          "check": "zig",
          "always": true
        },
        {
          "name": "lizard-complexity",
          "kind": "lizard",
          "check": "lizard",
          "always": true
        }
      ]
    }
  }
}
