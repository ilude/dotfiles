# Pi extension stacking recipes
# Recipes for launching Pi with different extension configurations

set windows-shell := ["pwsh.exe", "-Command"]

# Test recipes

# Run all extension tests
test:
    cd ~/.dotfiles/pi/tests && pnpm test

# Run tests in watch mode
test-watch:
    cd ~/.dotfiles/pi/tests && pnpm test:watch

# Run tests with coverage report
test-coverage:
    cd ~/.dotfiles/pi/tests && pnpm test:coverage

# Run deterministic memory eval scaffold (baseline mode)
eval-memory:
    cd ~/.dotfiles/pi/tests && bun memory-eval/runner.ts --memoryMode=baseline

# Rebuild local JSONL-derived in-memory expertise index
memory-rebuild:
    cd ~/.dotfiles && bun pi/scripts/memory-rebuild.ts

# Scan memory index for cross-repo promotion candidates (writes to ~/.pi/agent/index/, never tracked)
memory-promote-scan:
    cd ~/.dotfiles && bun pi/scripts/memory-promote-scan.ts

# Show what a snapshot archive would write (no side effects)
memory-snapshot-archive-dry-run:
    cd ~/.dotfiles && bun pi/scripts/memory-snapshot-archive.ts

# Actually write a snapshot archive under ~/.pi/agent/index/archive/{ts}/
memory-snapshot-archive-confirm:
    cd ~/.dotfiles && bun pi/scripts/memory-snapshot-archive.ts --confirm

# Restore-smoke an archive: copy mirrored snapshots to temp + parse + assert legacy shape
memory-snapshot-restore-smoke:
    cd ~/.dotfiles && bun pi/scripts/snapshot-restore-smoke.ts

# Default recipe — launches Pi with all auto-discovered extensions
default:
    pi

# Solo mode — Pi with no extensions, clean slate
solo:
    pi --no-extensions

# Damage control only (safety rules only)
safe:
    pi --no-extensions -e ~/.dotfiles/pi/extensions/damage-control.ts

# Full stack (all extensions)
full:
    pi --no-extensions -e ~/.dotfiles/pi/extensions/persistent-defaults.ts -e ~/.dotfiles/pi/extensions/damage-control.ts -e ~/.dotfiles/pi/extensions/bedrock-cost.ts -e ~/.dotfiles/pi/extensions/codex-status.ts -e ~/.dotfiles/pi/extensions/quality-gates.ts -e ~/.dotfiles/pi/extensions/session-hooks.ts -e ~/.dotfiles/pi/extensions/web-tools.ts -e ~/.dotfiles/pi/extensions/model-visibility.ts -e ~/.dotfiles/pi/extensions/bedrock-refresh.ts -e ~/.dotfiles/pi/extensions/prompt-router.ts

# Web tools only (search + fetch)
web:
    pi --no-extensions -e ~/.dotfiles/pi/extensions/damage-control.ts -e ~/.dotfiles/pi/extensions/web-tools.ts

# Prompt routing only (classify prompts, auto-switch models)
route:
    pi --no-extensions -e ~/.dotfiles/pi/extensions/persistent-defaults.ts -e ~/.dotfiles/pi/extensions/damage-control.ts -e ~/.dotfiles/pi/extensions/prompt-router.ts

# guard: full stack + commit message enforcement
guard:
    pi --no-extensions -e ~/.dotfiles/pi/extensions/persistent-defaults.ts -e ~/.dotfiles/pi/extensions/damage-control.ts -e ~/.dotfiles/pi/extensions/bedrock-cost.ts -e ~/.dotfiles/pi/extensions/codex-status.ts -e ~/.dotfiles/pi/extensions/quality-gates.ts -e ~/.dotfiles/pi/extensions/session-hooks.ts -e ~/.dotfiles/pi/extensions/web-tools.ts -e ~/.dotfiles/pi/extensions/model-visibility.ts -e ~/.dotfiles/pi/extensions/bedrock-refresh.ts -e ~/.dotfiles/pi/extensions/commit-guard.ts -e ~/.dotfiles/pi/extensions/prompt-router.ts

# transcript: opt-in sidecar interaction trace + purge command
transcript:
    pi --no-extensions -e ~/.dotfiles/pi/extensions/persistent-defaults.ts -e ~/.dotfiles/pi/extensions/damage-control.ts -e ~/.dotfiles/pi/extensions/session-hooks.ts -e ~/.dotfiles/pi/extensions/transcript-purge.ts -e ~/.dotfiles/pi/extensions/prompt-router.ts
