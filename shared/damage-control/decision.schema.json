{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.invalid/damage-control/decision.schema.json",
  "title": "Damage-control decision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "timestamp",
    "client",
    "sessionId",
    "tool",
    "ruleId",
    "actionSummary",
    "engineAction",
    "userDecision",
    "latencyMs",
    "latencyKind"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "client": { "enum": ["pi", "claude"] },
    "sessionId": { "type": "string", "minLength": 1, "maxLength": 120 },
    "toolUseId": { "type": "string", "minLength": 1, "maxLength": 120 },
    "tool": { "type": "string", "minLength": 1, "maxLength": 80 },
    "ruleId": { "type": "string", "minLength": 1, "maxLength": 240 },
    "matchedPattern": { "type": "string", "minLength": 1, "maxLength": 240 },
    "actionSummary": { "type": "string", "maxLength": 500 },
    "engineAction": { "enum": ["allow", "ask", "block"] },
    "userDecision": {
      "enum": [
        "approved",
        "denied",
        "denied_or_abandoned",
        "not_applicable",
        "not_present"
      ]
    },
    "latencyMs": { "type": "number", "minimum": 0 },
    "latencyKind": { "enum": ["exact", "estimated", "not_available"] }
  }
}
