{
  "version": 1,
  "waivers": [
    {
      "id": "pi-exfil-semantics-deferred",
      "match": {
        "section": "bashToolPatterns",
        "exfil": true
      },
      "reason": "Pi skips exfil rules because allowed-host bypass semantics are not implemented."
    },
    {
      "id": "pi-injection-mapping-deferred",
      "match": {
        "section": "injectionPatterns"
      },
      "reason": "Pi currently normalizes mapping-shaped injection patterns to an empty list."
    },
    {
      "id": "pi-secret-patterns-deferred",
      "match": {
        "section": "secretPatterns"
      },
      "reason": "Pi uses separate output-secret heuristics and does not load canonical secret patterns."
    },
    {
      "id": "pi-context-relaxation-deferred",
      "match": {
        "section": "contexts"
      },
      "reason": "Pi does not implement Claude context-specific policy relaxation."
    },
    {
      "id": "claude-read-confirm-extension",
      "match": {
        "section": "readConfirmPaths"
      },
      "reason": "Claude has no damage-control Read PreToolUse hook; read confirmation is currently a Pi-only extension."
    },
    {
      "id": "content-scan-requires-injection-support",
      "match": {
        "section": "contentScanPaths"
      },
      "reason": "Content-scan paths only take effect with the deferred mapping-shaped injection patterns."
    },
    {
      "id": "claude-directory-glob-exclusions-unreachable",
      "match": {
        "section": "zeroAccessExclusions",
        "ids": [
          "zeroAccessExclusions:0017",
          "zeroAccessExclusions:0018",
          "zeroAccessExclusions:0019",
          "zeroAccessExclusions:0039",
          "zeroAccessExclusions:0040",
          "zeroAccessExclusions:0041",
          "zeroAccessExclusions:0042",
          "zeroAccessExclusions:0043",
          "zeroAccessExclusions:0045",
          "zeroAccessExclusions:0049",
          "zeroAccessExclusions:0050",
          "zeroAccessExclusions:0051",
          "zeroAccessExclusions:0057",
          "zeroAccessExclusions:0060"
        ]
      },
      "reason": "Claude normalizes candidate paths before fnmatch, stripping the trailing separator required by these directory glob patterns, so they are unreachable."
    },
    {
      "id": "semantic-git-precedes-yaml-rule",
      "match": {
        "section": "bashToolPatterns",
        "ids": [
          "bashToolPatterns:0022",
          "bashToolPatterns:0023",
          "bashToolPatterns:0025",
          "bashToolPatterns:0031",
          "bashToolPatterns:0032",
          "bashToolPatterns:0038"
        ]
      },
      "reason": "Claude and Pi semantic Git analysis runs before these isolated YAML rules, so the YAML branch is unreachable."
    },
    {
      "id": "readonly-find-bypass-precedes-yaml-rule",
      "match": {
        "section": "bashToolPatterns",
        "ids": [
          "bashToolPatterns:0055",
          "bashToolPatterns:0056",
          "bashToolPatterns:0057",
          "bashToolPatterns:0058",
          "bashToolPatterns:0059"
        ]
      },
      "reason": "Claude classifies these find commands as read-only before YAML evaluation, so the isolated YAML branches are unreachable."
    },
    {
      "id": "node-wrapper-unwrapped-before-yaml-rule",
      "match": {
        "section": "bashToolPatterns",
        "ids": [
          "bashToolPatterns:0067"
        ]
      },
      "reason": "Claude unwraps node -e before YAML evaluation, removing the node prefix required by this pattern."
    },
    {
      "id": "linux-only-rules-not-runnable-on-windows",
      "match": {
        "section": "bashToolPatterns",
        "ids": [
          "bashToolPatterns:0143",
          "bashToolPatterns:0144",
          "bashToolPatterns:0145",
          "bashToolPatterns:0146",
          "bashToolPatterns:0147",
          "bashToolPatterns:0148"
        ]
      },
      "reason": "These rules are explicitly Linux-only and cannot reach their policy branch in the Windows oracle run."
    }
  ]
}
