#!/usr/bin/env python3
"""Decrypt per-path .encrypted/**/*.age artifacts into private/."""
from __future__ import annotations

import argparse
from pathlib import Path

from private_archive_lib import ENCRYPTED_DIR, PRIVATE_DIR, sync_decrypt


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--identity", required=True)
    parser.add_argument("--archive", dest="legacy_archive", help="legacy option; use --encrypted-dir")
    parser.add_argument("--encrypted-dir", default=str(ENCRYPTED_DIR))
    parser.add_argument("--output-dir", default=str(PRIVATE_DIR))
    parser.add_argument("--force", action="store_true")
    args = parser.parse_args()
    if args.legacy_archive:
        raise SystemExit("private.tar.age input is legacy; use per-file .encrypted/ artifacts")
    restored = sync_decrypt(Path(args.identity), Path(args.encrypted_dir), Path(args.output_dir), args.force)
    print(f"PASS: restored {len(restored)} private files to {args.output_dir}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
