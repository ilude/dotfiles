#!/bin/sh
set -eu

staged_paths=$(git diff --cached --name-only)
if [ -d private ] && [ -f config/age/recipients.txt ] && grep -Eq '^[[:space:]]*age1' config/age/recipients.txt; then
  scripts/private-archive-encrypt
  if [ -d .encrypted ]; then
    git add -A -- .encrypted
  fi
elif printf '%s
' "$staged_paths" | grep -Eq '^(private/|\.encrypted/)'; then
  echo "ERROR: private paths are staged but no usable age recipient is configured" >&2
  echo "Add an age1... recipient to config/age/recipients.txt, then rerun the commit." >&2
  exit 1
fi

exec scripts/private-archive-scan --staged
