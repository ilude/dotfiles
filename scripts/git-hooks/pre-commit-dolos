#!/bin/sh
set -eu

if [ -x bin/dolos.exe ]; then
  dolos=bin/dolos.exe
elif [ -x bin/dolos ]; then
  dolos=bin/dolos
else
  cat >&2 <<'EOF'
ERROR: Dolos executable not found. Build it with:
  cd tools/dolos && go build -o ../../bin/dolos.exe .
EOF
  exit 1
fi

"$dolos" scan --staged

# A linked worktree normally has the tracked artifact but no local plaintext
# vault or worktree-local Dolos index. Scanning staged paths is sufficient for
# artifact-only commits; status and packing apply only where private/ exists.
if [ ! -d private ]; then
  exit 0
fi

status_output=$("$dolos" status 2>&1) || status_code=$?
status_code=${status_code:-0}
case "$status_output" in
  *"status=diverged"*)
    printf '%s\n' "Dolos: private/ diverged from encrypted archive; packing private/." >&2
    "$dolos" pack private
    git add -- .dolos/artifacts/private.tar.gz.age
    "$dolos" scan --staged
    ;;
  *)
    if [ "$status_code" -ne 0 ]; then
      printf '%s\n' "$status_output" >&2
      exit "$status_code"
    fi
    ;;
esac
