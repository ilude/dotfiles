#!/usr/bin/env bash
# Run configured quality validators for an explicit list of files.
set -euo pipefail

if (($# == 0)); then
    echo "Usage: scripts/quality-check FILE..." >&2
    exit 2
fi

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec uv run python "$repo_root/claude/hooks/quality-validation/quality_validation_hook.py" --files "$@"
