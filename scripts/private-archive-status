#!/usr/bin/env python3
"""Report private encryption guardrail status without decrypting content."""
from __future__ import annotations

import subprocess
from pathlib import Path

from private_archive_lib import ENCRYPTED_DIR, is_blocked_path, recipients, staged_paths


def ok(cmd: list[str]) -> bool:
    return subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def main() -> int:
    print(f"age: {'ok' if ok(['age', '--version']) else 'missing'}")
    print(f"age-keygen: {'ok' if ok(['age-keygen', '-version']) else 'missing'}")
    try:
        recipient_count = len(recipients())
    except SystemExit:
        recipient_count = 0
    encrypted_files = list(ENCRYPTED_DIR.rglob("*.age")) if ENCRYPTED_DIR.exists() else []
    print(f"recipients: {'configured' if recipient_count else 'missing'}")
    print(f"encrypted_dir: {'present' if ENCRYPTED_DIR.exists() else 'missing'}")
    print(f"encrypted_files: {len(encrypted_files)}")
    blocked = [p for p in staged_paths() if is_blocked_path(p)] if Path('.git').exists() else []
    print(f"staged_plaintext_private: {len(blocked)}")
    print(f"hook: {'present' if Path('.git/hooks/pre-commit').exists() else 'missing'}")
    return 1 if blocked else 0


if __name__ == "__main__":
    raise SystemExit(main())
