#!/usr/bin/env python3
"""Report private archive guardrail status without decrypting content."""
from __future__ import annotations

import subprocess
from pathlib import Path

from private_archive_lib import ARCHIVE, RECIPIENTS, is_blocked_path, staged_paths


def ok(cmd: list[str]) -> bool:
    return subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL).returncode == 0


def main() -> int:
    print(f"age: {'ok' if ok(['age', '--version']) else 'missing'}")
    print(f"age-keygen: {'ok' if ok(['age-keygen', '-version']) else 'missing'}")
    print(f"recipients: {'present' if RECIPIENTS.exists() else 'missing'}")
    print(f"archive: {'present' if ARCHIVE.exists() else 'missing'}")
    print(f"archive_mtime: {int(ARCHIVE.stat().st_mtime) if ARCHIVE.exists() else 'n/a'}")
    blocked = [p for p in staged_paths() if is_blocked_path(p)] if Path('.git').exists() else []
    print(f"staged_plaintext_private: {len(blocked)}")
    print(f"hook: {'present' if Path('.git/hooks/pre-commit').exists() else 'missing'}")
    return 1 if blocked else 0


if __name__ == "__main__":
    raise SystemExit(main())
