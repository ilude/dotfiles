#!/usr/bin/env python3
"""Install the Dolos pre-commit hook."""
from __future__ import annotations

import argparse
import subprocess
from pathlib import Path

LINE = "scripts/git-hooks/pre-commit-dolos\n"
OLD_LINES = (
    "scripts/git-hooks/pre-commit-x-private\n",
    "scripts/install-x-private-hook\n",
)


def hook_path() -> Path:
    proc = subprocess.run(
        ["git", "rev-parse", "--git-path", "hooks/pre-commit"],
        check=True,
        text=True,
        capture_output=True,
    )
    return Path(proc.stdout.strip())


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()
    hook = hook_path()
    existing = hook.read_text(encoding="utf-8") if hook.exists() else "#!/bin/sh\n"
    migrated = existing
    for old in OLD_LINES:
        migrated = migrated.replace(old, "")
    if LINE in migrated:
        if migrated != existing and not args.dry_run:
            hook.write_text(migrated, encoding="utf-8")
        print("PASS: Dolos hook already installed")
        return 0
    if args.dry_run:
        action = "replace legacy hook line with" if migrated != existing else "append"
        print(f"DRY-RUN: would {action} {LINE.strip()} in {hook}")
        return 0
    hook.parent.mkdir(parents=True, exist_ok=True)
    hook.write_text(migrated.rstrip() + "\n" + LINE, encoding="utf-8")
    hook.chmod(0o755)
    print(f"PASS: Dolos hook installed at {hook}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
