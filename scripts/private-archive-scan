#!/usr/bin/env python3
"""Reject plaintext private archive paths in staged or supplied paths."""
from __future__ import annotations

import argparse
import sys
import tempfile
from pathlib import Path

from private_archive_lib import is_blocked_path, nul_paths, staged_paths


def main() -> int:
    parser = argparse.ArgumentParser()
    source = parser.add_mutually_exclusive_group(required=True)
    source.add_argument("--staged", action="store_true")
    source.add_argument("--paths-from")
    args = parser.parse_args()
    if args.staged:
        paths = staged_paths()
    else:
        paths_file = Path(args.paths_from)
        if not paths_file.exists():
            candidates = [
                Path(tempfile.gettempdir()) / paths_file.name,
                Path("C:/tmp") / paths_file.name,
            ]
            paths_file = next((candidate for candidate in candidates if candidate.exists()), paths_file)
        paths = nul_paths(paths_file.read_bytes())
    blocked = [path for path in paths if is_blocked_path(path)]
    if blocked:
        for path in blocked:
            print(f"BLOCKED private path: {path}", file=sys.stderr)
        return 1
    print("PASS: no plaintext private paths detected")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
