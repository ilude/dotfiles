#!/usr/bin/env python3
"""Resolve private.tar.age Git conflicts by decrypting stages and re-encrypting merged fixtures."""
from __future__ import annotations

import argparse
import shutil
import subprocess
import sys
from pathlib import Path

from private_archive_lib import copy_tree_merge, decrypt_to_tar, encrypt_tar, extract_tar, tempdir

PATH = "private.tar.age"


def stages() -> dict[str, str]:
    proc = subprocess.run(["git", "ls-files", "-u", "--", PATH], check=True, text=True, stdout=subprocess.PIPE)
    found = {}
    for line in proc.stdout.splitlines():
        meta, _ = line.split("\t", 1)
        stage = meta.split()[2]
        found[stage] = stage
    return found


def git_show(stage: str, dest: Path) -> None:
    with dest.open("wb") as fh:
        subprocess.run(["git", "show", f":{stage}:{PATH}"], check=True, stdout=fh)


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--identity", required=True)
    parser.add_argument("--keep-temp", action="store_true")
    args = parser.parse_args()
    found = stages()
    if not {"1", "2", "3"}.issubset(found):
        raise SystemExit("private.tar.age does not have base/ours/theirs conflict stages")
    tmp = tempdir("private-conflict-")
    root = Path(tmp.name)
    try:
        dirs = {}
        for stage, name in [("1", "base"), ("2", "ours"), ("3", "theirs")]:
            age_file = root / f"{name}.age"
            tar_file = root / f"{name}.tar"
            out_dir = root / name
            git_show(stage, age_file)
            decrypt_to_tar(age_file, Path(args.identity), tar_file)
            extract_tar(tar_file, out_dir)
            dirs[name] = out_dir
        merged = root / "merged"
        shutil.copytree(dirs["ours"], merged)
        conflicts = copy_tree_merge(dirs["theirs"], merged)
        if conflicts:
            manifest = Path("private.conflicts") / "manifest.txt"
            manifest.parent.mkdir(exist_ok=True)
            manifest.write_text("\n".join(sorted(conflicts)) + "\n", encoding="utf-8")
            print(f"CONFLICT: {len(conflicts)} path(s); see {manifest}", file=sys.stderr)
            return 1
        tar_file = root / "merged.tar"
        from private_archive_lib import make_tar
        make_tar(merged, tar_file)
        encrypt_encrypt = root / PATH
        encrypt_tar(tar_file, encrypt_encrypt)
        shutil.copy2(encrypt_encrypt, PATH)
        subprocess.run(["git", "add", PATH], check=True)
        print("PASS: resolved private.tar.age conflict")
        return 0
    finally:
        if args.keep_temp:
            print(f"WARNING: kept temporary decrypted paths under {root}", file=sys.stderr)
        else:
            tmp.cleanup()


if __name__ == "__main__":
    raise SystemExit(main())
