#!/usr/bin/env python3
"""Sync-encrypt private/ files into per-path .encrypted/**/*.age artifacts."""
from __future__ import annotations

import argparse
from pathlib import Path

from private_archive_lib import ENCRYPTED_DIR, PRIVATE_DIR, sync_encrypt


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--private-dir", default=str(PRIVATE_DIR))
    parser.add_argument("--output-dir", default=str(ENCRYPTED_DIR))
    parser.add_argument("--output", dest="legacy_output", help="legacy option; use --output-dir")
    args = parser.parse_args()
    if args.legacy_output:
        raise SystemExit("private.tar.age output is legacy; use per-file .encrypted/ artifacts")
    written = sync_encrypt(Path(args.private_dir), Path(args.output_dir))
    print(f"PASS: synced {len(written)} encrypted private files to {args.output_dir}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
