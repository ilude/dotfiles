#!/usr/bin/env python3
"""Safe Brave + agent-browser helper for Pi agents."""

from __future__ import annotations

import argparse
import json
import os
import shutil
import socket
import subprocess
import sys
import time
import urllib.request
from pathlib import Path

STATE_DIR = Path(".pi/agent-browser-brave")
STATE_PATH = STATE_DIR / "state.json"
PI_PROFILE_DIR = STATE_DIR / "brave-user-data"
SESSION_ID = "pi-agent-browser-brave"


def run(cmd: list[str], check: bool = False) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, text=True, capture_output=True, check=check)


def is_windows() -> bool:
    return sys.platform.startswith("win") or "MINGW" in os.environ.get("MSYSTEM", "")


def resolve_agent_browser() -> tuple[list[str], str]:
    local = shutil.which("agent-browser")
    if local:
        return [local], f"installed:{local}"
    npx = shutil.which("npx")
    if npx:
        return [npx, "-y", "agent-browser"], "npx-fallback:agent-browser"
    return [], "missing"


def find_brave() -> str | None:
    env_path = os.environ.get("BRAVE_PATH")
    if env_path and Path(env_path).exists():
        return env_path
    names = ["brave", "brave-browser", "brave.exe"]
    for name in names:
        found = shutil.which(name)
        if found:
            return found
    if is_windows():
        candidates = []
        for base in (
            os.environ.get("LOCALAPPDATA"),
            os.environ.get("PROGRAMFILES"),
            os.environ.get("PROGRAMFILES(X86)"),
        ):
            if base:
                candidates.append(Path(base) / "BraveSoftware/Brave-Browser/Application/brave.exe")
        for candidate in candidates:
            if candidate.exists():
                return str(candidate)
    return None


def default_brave_user_data_dir() -> Path | None:
    env_path = os.environ.get("BRAVE_USER_DATA_DIR")
    if env_path:
        return Path(env_path)
    if is_windows():
        local_app_data = os.environ.get("LOCALAPPDATA")
        return (
            Path(local_app_data) / "BraveSoftware/Brave-Browser/User Data"
            if local_app_data
            else None
        )
    if sys.platform == "darwin":
        return Path.home() / "Library/Application Support/BraveSoftware/Brave-Browser"
    return Path.home() / ".config/BraveSoftware/Brave-Browser"


def normalize_brave_profile_directory(profile: str) -> str:
    # Chromium profile directory names are stable across machines even when the
    # display name differs. The default Brave profile directory is "Default";
    # on this machine its display name is "Work", but other machines may show
    # a different display name while still using the Default directory.
    return "Default" if profile.strip().lower() in {"", "default", "work"} else profile


def free_port() -> int:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.bind(("127.0.0.1", 0))
        return int(sock.getsockname()[1])


def load_state() -> dict:
    if not STATE_PATH.exists():
        return {}
    try:
        return json.loads(STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return {}


def save_state(state: dict) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_PATH.write_text(json.dumps(state, indent=2) + "\n", encoding="utf-8")


def redact(path: str | None) -> str:
    if not path:
        return ""
    text = str(path).replace("\\", "/")
    home = str(Path.home()).replace("\\", "/")
    if home and text.lower().startswith(home.lower()):
        return "<HOME>" + text[len(home) :]
    return text


def cdp_json(port: int, path: str = "/json/version") -> dict | list | None:
    try:
        with urllib.request.urlopen(f"http://127.0.0.1:{port}{path}", timeout=2) as resp:
            return json.loads(resp.read().decode("utf-8", errors="replace"))
    except Exception:
        return None


def wait_cdp(port: int) -> bool:
    for _ in range(40):
        if cdp_json(port):
            return True
        time.sleep(0.25)
    return False


def brave_identity(port: int, exe: str | None, user_data_dir: str | None) -> bool:
    version = cdp_json(port) or {}
    browser = str(version.get("Browser", "")).lower() if isinstance(version, dict) else ""
    exe_l = (exe or "").lower()
    data_l = (user_data_dir or "").lower()
    return "brave" in browser or "brave" in exe_l or "bravesoftware" in data_l


def launch(args: argparse.Namespace, command_source: str) -> dict:
    brave = find_brave()
    if not brave:
        raise SystemExit("ERROR: Brave executable not found. Install Brave or set BRAVE_PATH.")
    port = int(args.port) if args.port else free_port()
    real_profile = "Default" if args.real_brave_default else args.real_brave_profile
    if real_profile:
        print("WARNING: real Brave profile mode can control logged-in sites.", file=sys.stderr)
        print(
            "The default Brave profile directory is 'Default' even if its "
            "display name is 'Work' or another local name.",
            file=sys.stderr,
        )
        brave_user_data = default_brave_user_data_dir()
        if not brave_user_data:
            raise SystemExit(
                "ERROR: could not resolve Brave user data directory. Set BRAVE_USER_DATA_DIR."
            )
        user_data_dir = str(brave_user_data)
        profile_dir = normalize_brave_profile_directory(real_profile)
        profile_mode = "real"
    else:
        user_data_dir = str(PI_PROFILE_DIR.resolve())
        profile_dir = "Pi"
        profile_mode = "pi"
        PI_PROFILE_DIR.mkdir(parents=True, exist_ok=True)
    cmd = [
        brave,
        "--remote-debugging-address=127.0.0.1",
        f"--remote-debugging-port={port}",
        f"--user-data-dir={user_data_dir}",
        f"--profile-directory={profile_dir}",
        "--no-first-run",
        "--no-default-browser-check",
    ]
    if args.open:
        cmd.append(args.open)
    proc = subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if not wait_cdp(port):
        raise SystemExit("ERROR: Brave launched but CDP endpoint did not become available.")
    if not brave_identity(port, brave, user_data_dir):
        raise SystemExit("ERROR: CDP endpoint did not prove Brave identity; refusing to continue.")
    state = {
        "pid": proc.pid,
        "processStartTime": None,
        "executablePath": brave,
        "userDataDir": user_data_dir,
        "profileDirectory": profile_dir,
        "profileMode": profile_mode,
        "cdpPort": port,
        "startedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
        "sessionId": SESSION_ID,
        "agentBrowserCommandSource": command_source,
    }
    save_state(state)
    return state


def agent_cmd(state: dict, subcommand: list[str]) -> int:
    base, _source = resolve_agent_browser()
    if not base:
        print(
            "ERROR: agent-browser unavailable. Install Node.js/npx or agent-browser.",
            file=sys.stderr,
        )
        return 1
    cmd = base + ["--cdp", str(state["cdpPort"]), "--session", SESSION_ID] + subcommand
    proc = subprocess.run(cmd, text=True)
    return proc.returncode


def status() -> int:
    state = load_state()
    if not state:
        print("status: no owned session state")
        return 0
    port = int(state.get("cdpPort", 0) or 0)
    online = bool(port and cdp_json(port))
    safe = (
        brave_identity(port, state.get("executablePath"), state.get("userDataDir"))
        if online
        else False
    )
    print("status: owned session record found")
    print(f"profileMode: {state.get('profileMode')}")
    print(f"cdpEndpoint: http://127.0.0.1:{port}")
    print(f"cdpOnline: {str(online).lower()}")
    print(f"braveIdentityVerified: {str(safe).lower()}")
    print(f"agentBrowserCommandSource: {state.get('agentBrowserCommandSource')}")
    print(f"executablePath: {redact(state.get('executablePath'))}")
    print(f"userDataDir: {redact(state.get('userDataDir'))}")
    return 0


def close_owned() -> int:
    state = load_state()
    if not state:
        print("close-owned: no owned session state")
        return 0
    port = int(state.get("cdpPort", 0) or 0)
    pid = int(state.get("pid", 0) or 0)
    if (
        not port
        or not pid
        or not cdp_json(port)
        or not brave_identity(port, state.get("executablePath"), state.get("userDataDir"))
    ):
        print("close-owned: refusing to terminate because identity checks failed")
        print("Manual cleanup: close the dedicated Pi Brave window yourself.")
        return 1
    try:
        if is_windows():
            subprocess.run(
                ["powershell", "-NoProfile", "-Command", f"Stop-Process -Id {pid}"], check=False
            )
        else:
            os.kill(pid, 15)
    except Exception as exc:
        print(f"close-owned: failed to terminate owned pid {pid}: {exc}")
        return 1
    STATE_PATH.unlink(missing_ok=True)
    print(f"close-owned: closed owned Brave pid {pid}; no broad browser kill attempted")
    return 0


def print_check(command_source: str) -> int:
    base, _ = resolve_agent_browser()
    brave = find_brave()
    print(f"agentBrowserCommandSource: {command_source}")
    print(f"braveExecutable: {redact(brave)}" if brave else "braveExecutable: missing")
    if not base:
        print(
            "ERROR: agent-browser unavailable. Install Node.js/npx or agent-browser; "
            "no global mutation was performed."
        )
        return 1
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(description="Safe Brave + agent-browser helper for Pi agents")
    parser.add_argument(
        "--check",
        action="store_true",
        help="Report agent-browser and Brave availability without mutating global install state",
    )
    parser.add_argument("--status", action="store_true", help="Show sanitized owned-session status")
    parser.add_argument(
        "--open", metavar="URL", help="Launch/open URL in dedicated Pi Brave profile by default"
    )
    parser.add_argument(
        "--title", action="store_true", help="Print page title through agent-browser"
    )
    parser.add_argument(
        "--snapshot", action="store_true", help="Print accessibility snapshot through agent-browser"
    )
    parser.add_argument(
        "--screenshot", metavar="PATH", help="Capture screenshot through agent-browser"
    )
    parser.add_argument(
        "--close-owned",
        action="store_true",
        help="Close only the identity-verified owned Brave session",
    )
    parser.add_argument("--port", type=int, help="Explicit loopback CDP port; default is ephemeral")
    parser.add_argument(
        "--real-brave-profile",
        metavar="PROFILE",
        help=(
            "Use real Brave profile directory name. Use Default for the default "
            "Brave profile, regardless of display name."
        ),
    )
    parser.add_argument(
        "--real-brave-default",
        action="store_true",
        help=(
            "Use the real default Brave profile directory (Default), regardless of "
            "local display name such as Work"
        ),
    )
    base, source = resolve_agent_browser()
    args = parser.parse_args()

    if args.check:
        return print_check(source)
    if args.status:
        return status()
    if args.close_owned:
        return close_owned()
    state = load_state()
    if args.open or args.real_brave_profile or args.real_brave_default:
        state = launch(args, source)
    if not state and (args.title or args.snapshot or args.screenshot):
        print("ERROR: no owned session; run --open first", file=sys.stderr)
        return 1
    rc = 0
    if args.title:
        rc = agent_cmd(state, ["get", "title"]) or rc
    if args.snapshot:
        rc = agent_cmd(state, ["snapshot"]) or rc
    if args.screenshot:
        rc = agent_cmd(state, ["screenshot", args.screenshot]) or rc
    if args.open and not (args.title or args.snapshot or args.screenshot):
        print(f"opened: {args.open}")
        print(f"profileMode: {state['profileMode']}")
        print(f"cdpEndpoint: http://127.0.0.1:{state['cdpPort']}")
        print(f"agentBrowserCommandSource: {state['agentBrowserCommandSource']}")
    if not any(
        [
            args.check,
            args.status,
            args.close_owned,
            args.open,
            args.title,
            args.snapshot,
            args.screenshot,
            args.real_brave_profile,
            args.real_brave_default,
        ]
    ):
        parser.print_help()
    return rc


if __name__ == "__main__":
    raise SystemExit(main())
