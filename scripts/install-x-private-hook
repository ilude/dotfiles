#!/usr/bin/env python3
"""Install the X private-data pre-commit hook."""
from __future__ import annotations

import argparse
from pathlib import Path

HOOK = Path(".git/hooks/pre-commit")
LINE = "scripts/git-hooks/pre-commit-x-private\n"


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument("--dry-run", action="store_true")
    args = parser.parse_args()
    existing = HOOK.read_text(encoding="utf-8") if HOOK.exists() else "#!/bin/sh\n"
    if LINE in existing:
        print("PASS: hook already installed")
        return 0
    if args.dry_run:
        print(f"DRY-RUN: would append {LINE.strip()} to {HOOK}")
        return 0
    HOOK.parent.mkdir(parents=True, exist_ok=True)
    HOOK.write_text(existing.rstrip() + "\n" + LINE, encoding="utf-8")
    HOOK.chmod(0o755)
    print("PASS: hook installed")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
