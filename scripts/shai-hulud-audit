def has_setting(text: str, name: str, value: str | None = None) -> bool:
    """Return whether a simple ``key=value`` or ``key: value`` setting exists.

    This intentionally handles only the small cross-file setting forms used by
    npmrc, pnpm YAML, bunfig-adjacent text, and TOML snippets in this script.
    It is a low-noise heuristic, not a complete parser for every format.
    """
    if value is None:
        return re.search(rf"(?m)^\s*{re.escape(name)}\s*[:=]", text) is not None
    return re.search(rf"(?m)^\s*{re.escape(name)}\s*[:=]\s*{re.escape(value)}\s*$", text, re.IGNORECASE) is not None


def read_nearby_config(project_dir: Path, names: list[str]) -> str:
    """Concatenate named config files that exist directly under ``project_dir``."""
    parts: list[str] = []
    for name in names:
        path = project_dir / name
        if path.exists():
            parts.append(read_text(path))
    return "\n".join(parts)


def read_nuget_config_chain(project_dir: Path) -> str:
    """Read NuGet/MSBuild config from a project directory and its ancestors."""
    names = ["NuGet.config", "Directory.Build.props", "Directory.Packages.props"]
    parts = [read_nearby_config(project_dir, names)]
    for parent in project_dir.parents:
        parts.append(read_nearby_config(parent, names))
    return "\n".join(part for part in parts if part)


def check_javascript_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check npm, pnpm, and Bun install-time execution controls."""
    findings: list[Finding] = []
    js_config = read_nearby_config(project_dir, [".npmrc", "pnpm-workspace.yaml", "pnpm-workspace.yml", "package.json"])
    bun_config = read_nearby_config(project_dir, ["bunfig.toml", ".npmrc", "package.json"])

    if {"pnpm-lock.yaml", "pnpm-workspace.yaml", "pnpm-workspace.yml"} & names:
        for setting, expected in [
            ("minimumReleaseAge", None),
            ("blockExoticSubdeps", "true"),
            ("strictDepBuilds", "true"),
        ]:
            if not has_setting(js_config, setting, expected):
                findings.append(Finding(
                    "recommendation",
                    "pnpm-hardening-missing",
                    str(project_dir),
                    evidence=f"Set {setting}{'=' + expected if expected else ' to a positive cooldown'} in .npmrc or pnpm-workspace.yaml",
                ))
        if has_setting(js_config, "dangerouslyAllowAllBuilds", "true"):
            findings.append(Finding(
                "recommendation",
                "pnpm-dangerous-setting-enabled",
                str(project_dir),
                evidence="Avoid dangerouslyAllowAllBuilds=true; use explicit allowBuilds/onlyBuiltDependencies instead",
            ))

    if "package-lock.json" in names or "npm-shrinkwrap.json" in names:
        if not has_setting(js_config, "ignore-scripts", "true"):
            findings.append(Finding(
                "recommendation",
                "npm-hardening-missing",
                str(project_dir),
                evidence="Consider ignore-scripts=true in project .npmrc; use explicit reviewed rebuilds for native deps",
            ))

    if {"bun.lock", "bun.lockb"} & names:
        if not (
            has_setting(bun_config, "ignoreScripts", "true")
            or has_setting(bun_config, "install.ignoreScripts", "true")
            or has_setting(bun_config, "ignore-scripts", "true")
        ):
            findings.append(Finding(
                "recommendation",
                "bun-hardening-missing",
                str(project_dir),
                evidence="Consider [install] ignoreScripts=true in bunfig.toml or ignore-scripts=true in .npmrc; use trustedDependencies only for reviewed build scripts",
            ))
    return findings


def check_python_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check pip requirements hash mode and uv resolver hardening."""
    findings: list[Finding] = []
    if any(name.startswith("requirements") and name.endswith(".txt") for name in names):
        req_text = read_nearby_config(project_dir, [name for name in names if name.startswith("requirements") and name.endswith(".txt")])
        has_requirement = any(
            line.strip()
            and not line.lstrip().startswith(("#", "-", "--"))
            for line in req_text.splitlines()
        )
        if has_requirement and "--hash=" not in req_text and "--require-hashes" not in req_text:
            findings.append(Finding(
                "recommendation",
                "pip-hardening-missing",
                str(project_dir),
                evidence="For pip requirements, consider --require-hashes with fully pinned hashes; prefer wheels-only where practical",
            ))

    if {"uv.lock", "pyproject.toml"} & names:
        uv_config = read_nearby_config(project_dir, ["uv.toml", "pyproject.toml"])
        for setting, expected in [
            ("exclude-newer", None),
            ("index-strategy", '"first-index"'),
            ("no-sources", "true"),
            ("no-build", "true"),
        ]:
            if not has_setting(uv_config, setting, expected):
                findings.append(Finding(
                    "recommendation",
                    "uv-hardening-missing",
                    str(project_dir),
                    evidence=f"Set tool.uv {setting}{'=' + expected if expected else ' to a dependency cooldown'}",
                ))
    return findings


def check_nuget_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check NuGet lockfile enforcement and source mapping."""
    findings: list[Finding] = []
    if not (any(name.endswith(".csproj") for name in names) or "packages.lock.json" in names):
        return findings

    nuget_config = read_nuget_config_chain(project_dir)
    if "packages.lock.json" not in names:
        findings.append(Finding(
            "recommendation",
            "nuget-lockfile-missing",
            str(project_dir),
            evidence="Enable NuGet lock files with RestorePackagesWithLockFile=true and commit packages.lock.json",
        ))
    if "packages.lock.json" in names and not re.search(r"<RestoreLockedMode>\s*true\s*</RestoreLockedMode>", nuget_config, re.IGNORECASE):
        findings.append(Finding(
            "recommendation",
            "nuget-locked-mode-missing",
            str(project_dir),
            evidence="Set RestoreLockedMode=true for CI/checked restores so packages.lock.json is enforced",
        ))
    if "<packageSourceMapping>" not in nuget_config:
        findings.append(Finding(
            "recommendation",
            "nuget-source-mapping-missing",
            str(project_dir),
            evidence="Consider NuGet packageSourceMapping in NuGet.config to bind package ID patterns to trusted feeds",
        ))
    return findings


def check_go_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check Go module checksum files and recommended user/runner defaults."""
    if "go.mod" not in names:
        return []
    findings: list[Finding] = []
    if "go.sum" not in names:
        findings.append(Finding(
            "recommendation",
            "go-sum-missing",
            str(project_dir),
            evidence="Commit go.sum and run go mod verify in CI; keep GOSUMDB enabled and avoid GOINSECURE/GONOSUMDB=*",
        ))
    findings.append(Finding(
        "recommendation",
        "go-env-hardening-review",
        str(project_dir),
        evidence="Recommended: go env -w GOPROXY=https://proxy.golang.org,direct GOSUMDB=sum.golang.org GOVCS=public:git,private:all",
    ))
    return findings


def check_cargo_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check Rust lockfile and cargo-deny policy presence."""
    if "Cargo.toml" not in names:
        return []
    findings: list[Finding] = []
    cargo_text = read_nearby_config(project_dir, ["Cargo.toml"])
    is_workspace = "[workspace]" in cargo_text
    if "Cargo.lock" not in names and not is_workspace:
        findings.append(Finding(
            "recommendation",
            "cargo-lock-missing",
            str(project_dir),
            evidence="For Rust applications, commit Cargo.lock and use cargo fetch/test --locked in CI",
        ))
    if not (project_dir / "deny.toml").exists():
        findings.append(Finding(
            "recommendation",
            "cargo-deny-missing",
            str(project_dir),
            evidence="Consider cargo install cargo-deny; cargo deny init; cargo deny check for advisories/licenses/sources",
        ))
    return findings


def check_maven_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check Maven dynamic versions and local settings checksum policy."""
    if "pom.xml" not in names:
        return []
    findings: list[Finding] = []
    pom_text = read_nearby_config(project_dir, ["pom.xml"])
    settings_text = read_nearby_config(project_dir, ["settings.xml"])
    if re.search(r">\s*(LATEST|RELEASE|\[[^\]]*,\)|\([^)]*,\))\s*<", pom_text):
        findings.append(Finding(
            "recommendation",
            "maven-dynamic-version",
            str(project_dir),
            evidence="Avoid Maven dynamic/range versions like LATEST, RELEASE, [1.0,); pin exact versions",
        ))
    if settings_text and "<checksumPolicy>fail</checksumPolicy>" not in settings_text:
        findings.append(Finding(
            "recommendation",
            "maven-checksum-policy-review",
            str(project_dir),
            evidence="In settings.xml/repository config, prefer checksumPolicy=fail; often enforced by Nexus/Artifactory",
        ))
    return findings


def check_bundler_hardening(project_dir: Path, names: set[str]) -> list[Finding]:
    """Check Bundler frozen/deployment mode and lockfile checksums."""
    if "Gemfile.lock" not in names:
        return []
    findings: list[Finding] = []
    bundle_config = read_nearby_config(project_dir, [".bundle/config", "Gemfile.lock"])
    if "BUNDLE_FROZEN" not in bundle_config and "BUNDLE_DEPLOYMENT" not in bundle_config:
        findings.append(Finding(
            "recommendation",
            "bundler-frozen-missing",
            str(project_dir),
            evidence="Consider bundle config set --local frozen true; bundle config set --local deployment true; run bundle audit check",
        ))
    if "CHECKSUMS" not in bundle_config:
        findings.append(Finding(
            "recommendation",
            "bundler-checksums-missing",
            str(project_dir),
            evidence="On modern Bundler, consider bundle lock --add-checksums to verify gem contents",
        ))
    return findings


def hardening_recommendations(project_dirs: dict[Path, set[str]]) -> list[Finding]:
    """Produce non-failing supply-chain hardening recommendations.

    ``project_dirs`` maps each directory to the package-manager files found in
    that directory. Recommendations are deliberately conservative: they point to
    settings that reduce install-time code execution, enforce lockfiles, or pin
    dependency provenance, but they do not claim the project is compromised.
    """
    findings: list[Finding] = []
    checkers = [
        check_javascript_hardening,
        check_python_hardening,
        check_nuget_hardening,
        check_go_hardening,
        check_cargo_hardening,
        check_maven_hardening,
        check_bundler_hardening,
    ]
    for project_dir, names in sorted(project_dirs.items(), key=lambda item: str(item[0]).casefold()):
        for checker in checkers:
            findings.extend(checker(project_dir, names))
    return findings


def load_npm() -> None:
    """Parse the embedded affected npm package/version table into a mapping."""
    for line in AFFECTED_NPM_TEXT.strip().splitlines():
        name, versions = line.split(":", 1)
        AFFECTED_NPM[name.strip()] = {v.strip() for v in versions.split(",")}


def version_patterns(name: str, version: str) -> list[re.Pattern[str]]:
    """Build regexes for common lockfile/manifest package-version forms."""
    n = re.escape(name)
    v = re.escape(version)
    return [
        re.compile(rf"['\"]?{n}['\"]?\s*[:@]\s*['\"]?(?:[~^=<> ]*){v}(?:[^0-9A-Za-z_.-]|$)"),
        re.compile(rf"/{n}/{v}(?:[^0-9A-Za-z_.-]|$)"),
        re.compile(rf"{n}@{v}(?:[^0-9A-Za-z_.-]|$)"),
        re.compile(rf"name\s*=\s*['\"]{n}['\"][\s\S]{{0,300}}version\s*=\s*['\"]{v}['\"]"),
    ]


def iter_files(root: Path, include_node_modules: bool) -> tuple[list[Path], int]:
    """Return package-manager and IOC candidate files under ``root``.

    Large generated directories are skipped by default. ``node_modules`` is
    skipped for repository scans but included for discovered global installs or
    when the user explicitly passes ``--include-node-modules``.
    """
    files: list[Path] = []
    skipped = 0
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS and (include_node_modules or d != NODE_MODULES)]
        for fn in filenames:
            p = Path(dirpath) / fn
            if (
                fn in SCAN_NAMES
                or fn.endswith(".csproj")
                or fn in {"router_init.js", "router_runtime.js", "tanstack_runner.js", "transformers.pyz", "pgmonitor.py"}
            ):
                files.append(p)
            elif include_node_modules and fn == "package.json":
                files.append(p)
            else:
                skipped += 1
    return files, skipped


def read_text(path: Path) -> str:
    """Read a small text file as UTF-8 with replacement; return empty on error."""
    try:
        if path.stat().st_size > 15_000_000:
            return ""
        return path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return ""


def scan_file(path: Path, text: str) -> list[Finding]:
    """Scan one file for critical IOCs and known affected package versions."""
    out: list[Finding] = []
    low = text.lower()
    for ioc in IOCS:
        if ioc.lower() in low or path.name == ioc:
            out.append(Finding("critical", "ioc", str(path), evidence=ioc))
    for pkg, versions in AFFECTED_NPM.items():
        if pkg not in text:
            continue
        for ver in versions:
            if any(p.search(text) for p in version_patterns(pkg, ver)):
                out.append(Finding("critical", "affected-npm-version", str(path), pkg, ver))
    for pkg, versions in AFFECTED_PYPI.items():
        if pkg.lower() not in low:
            continue
        for ver in versions:
            if any(p.search(text) for p in version_patterns(pkg, ver)):
                out.append(Finding("critical", "affected-pypi-version", str(path), pkg, ver))
    for pkg in SUSPICIOUS_PYPI_NAMES:
        if pkg in low and path.name in {"requirements.txt", "pyproject.toml", "uv.lock", "poetry.lock", "Pipfile.lock"}:
            out.append(Finding("info", "pypi-package-present-review-version", str(path), pkg))
    return out


def print_recommendation_summary(findings: list[Finding]) -> None:
    """Print grouped remediation guidance instead of hundreds of raw rows."""
    grouped: dict[str, list[Finding]] = defaultdict(list)
    for finding in findings:
        if finding.severity == "recommendation":
            grouped[finding.kind].append(finding)
    if not grouped:
        return
    print("\nRecommended setup commands:")
    for kind in sorted(grouped):
        items = grouped[kind]
        paths = sorted({item.path for item in items}, key=str.casefold)
        print(f"\n[{kind}] {len(items)} finding(s), {len(paths)} path(s)")
        fix = REMEDIATIONS.get(kind, items[0].evidence or "Review project configuration.")
        print(f"  Fix: {fix}")
        for path in paths[:5]:
            print(f"  - {path}")
        if len(paths) > 5:
            print(f"  - ... {len(paths) - 5} more")


def main() -> int:
    """CLI entrypoint. Return 2 only when critical compromise findings exist."""
    load_npm()
    parser = argparse.ArgumentParser(
        description="Audit trees for Mini Shai-Hulud package IOCs",
        epilog=(
            "Examples: %(prog)s C:/projects | "
            "%(prog)s C:/projects --json > audit.json | "
            "%(prog)s C:/projects --no-hardening-recommendations"
        ),
    )
    parser.add_argument("roots", nargs="*", default=["."], help="roots to scan, e.g. C:/projects")
    parser.add_argument(
        "--no-default-installs",
        action="store_true",
        help="do not add discovered npm/pnpm/bun/Python global and user installs",
    )
    parser.add_argument(
        "--include-node-modules",
        action="store_true",
        help="also scan node_modules package files/payloads",
    )
    parser.add_argument("--json", action="store_true", help="emit JSON")
    parser.add_argument(
        "--warn-package-names",
        action="store_true",
        help="also report non-critical affected-ecosystem package-name presence",
    )
    parser.add_argument(
        "--no-hardening-recommendations",
        action="store_true",
        help="do not report package-manager supply-chain hardening recommendations",
    )
    parser.add_argument(
        "--list-all-recommendations",
        action="store_true",
        help="print every recommendation instead of grouped setup commands",
    )
    args = parser.parse_args()

    findings: list[Finding] = []
    scanned = 0
    project_dirs: dict[Path, set[str]] = {}
    roots = existing_paths([Path(r) for r in args.roots])
    if not args.no_default_installs:
        roots = default_scan_roots(args.roots)
    for root in roots:
        include_node_modules = args.include_node_modules or root.name == "node_modules"
        files, _ = iter_files(root, include_node_modules)
        for path in files:
            if path.name in SCAN_NAMES:
                project_dirs.setdefault(path.parent, set()).add(path.name)
            scanned += 1
            file_findings = scan_file(path, read_text(path))
            if not args.warn_package_names:
                file_findings = [f for f in file_findings if f.severity != "info"]
            findings.extend(file_findings)

    if not args.no_hardening_recommendations:
        findings.extend(hardening_recommendations(project_dirs))

    critical = [f for f in findings if f.severity == "critical"]
    result = {
        "roots": [str(r) for r in roots],
        "scanned_files": scanned,
        "critical_count": len(critical),
        "recommendation_count": len([f for f in findings if f.severity == "recommendation"]),
        "findings": [asdict(f) for f in findings],
    }
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(f"Roots: {len(roots)}")
        for root in roots:
            print(f"  {root}")
        print(f"Scanned files: {scanned}")
        print(f"Critical findings: {len(critical)}")
        print(f"Recommendations: {len([f for f in findings if f.severity == 'recommendation'])}")
        for f in findings:
            if f.severity == "recommendation" and not args.list_all_recommendations:
                continue
            pkg = f" {f.package}@{f.version}" if f.package and f.version else f" {f.package}" if f.package else ""
            ev = f" evidence={f.evidence}" if f.evidence else ""
            print(f"[{f.severity}] {f.kind}{pkg} {f.path}{ev}")
        if not args.list_all_recommendations:
            print_recommendation_summary(findings)
    return 2 if critical else 0


if __name__ == "__main__":
    raise SystemExit(main())
