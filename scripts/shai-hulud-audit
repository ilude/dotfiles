"""

IOCS = [
    "@tanstack/setup",
    "github:tanstack/router#79ac49eedf774dd4b0cfa308722bc463cfe5885c",
    "bun run tanstack_runner.js",
    "router_init.js",
    "router_runtime.js",
    "tanstack_runner.js",
    "ab4fcadaec49c03278063dd269ea5eef82d24f2124a8e15d7b90f2fa8601266c",
    "2ec78d556d696e208927cc503d48e4b5eb56b31abc2870c2ed2e98d6be27fc96",
    "git-tanstack.com",
    "transformers.pyz",
    "83.142.209.194",
    "pgmonitor.py",
    "pgsql-monitor.service",
]

SCAN_NAMES = {
    "package.json", "package-lock.json", "npm-shrinkwrap.json", "pnpm-lock.yaml",
    "yarn.lock", "bun.lock", "bun.lockb", "pyproject.toml", "requirements.txt",
    "requirements-dev.txt", "requirements.lock", "uv.lock", "poetry.lock", "Pipfile.lock",
}
SKIP_DIRS = {".git", ".hg", ".svn", ".venv", "venv", "__pycache__", ".mypy_cache", ".pytest_cache", ".ruff_cache", "dist", "build"}
NODE_MODULES = "node_modules"

@dataclass
class Finding:
    severity: str
    kind: str
    path: str
    package: str | None = None
    version: str | None = None
    evidence: str | None = None


def load_npm() -> None:
    for line in AFFECTED_NPM_TEXT.strip().splitlines():
        name, versions = line.split(":", 1)
        AFFECTED_NPM[name.strip()] = {v.strip() for v in versions.split(",")}


def version_patterns(name: str, version: str) -> list[re.Pattern[str]]:
    n = re.escape(name)
    v = re.escape(version)
    return [
        re.compile(rf"['\"]?{n}['\"]?\s*[:@]\s*['\"]?(?:[~^=<> ]*){v}(?:[^0-9A-Za-z_.-]|$)"),
        re.compile(rf"/{n}/{v}(?:[^0-9A-Za-z_.-]|$)"),
        re.compile(rf"{n}@{v}(?:[^0-9A-Za-z_.-]|$)"),
        re.compile(rf"name\s*=\s*['\"]{n}['\"][\s\S]{{0,300}}version\s*=\s*['\"]{v}['\"]"),
    ]


def iter_files(root: Path, include_node_modules: bool) -> tuple[list[Path], int]:
    files: list[Path] = []
    skipped = 0
    for dirpath, dirnames, filenames in os.walk(root):
        dirnames[:] = [d for d in dirnames if d not in SKIP_DIRS and (include_node_modules or d != NODE_MODULES)]
        for fn in filenames:
            p = Path(dirpath) / fn
            if fn in SCAN_NAMES or fn in {"router_init.js", "router_runtime.js", "tanstack_runner.js", "transformers.pyz", "pgmonitor.py"}:
                files.append(p)
            elif include_node_modules and fn == "package.json":
                files.append(p)
            else:
                skipped += 1
    return files, skipped


def read_text(path: Path) -> str:
    try:
        if path.stat().st_size > 15_000_000:
            return ""
        return path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return ""


def scan_file(path: Path, text: str) -> list[Finding]:
    out: list[Finding] = []
    low = text.lower()
    for ioc in IOCS:
        if ioc.lower() in low or path.name == ioc:
            out.append(Finding("critical", "ioc", str(path), evidence=ioc))
    for pkg, versions in AFFECTED_NPM.items():
        if pkg not in text:
            continue
        for ver in versions:
            if any(p.search(text) for p in version_patterns(pkg, ver)):
                out.append(Finding("critical", "affected-npm-version", str(path), pkg, ver))
    for pkg, versions in AFFECTED_PYPI.items():
        if pkg.lower() not in low:
            continue
        for ver in versions:
            if any(p.search(text) for p in version_patterns(pkg, ver)):
                out.append(Finding("critical", "affected-pypi-version", str(path), pkg, ver))
    for pkg in SUSPICIOUS_PYPI_NAMES:
        if pkg in low and path.name in {"requirements.txt", "pyproject.toml", "uv.lock", "poetry.lock", "Pipfile.lock"}:
            out.append(Finding("info", "pypi-package-present-review-version", str(path), pkg))
    return out


def main() -> int:
    load_npm()
    parser = argparse.ArgumentParser(description="Audit trees for Mini Shai-Hulud package IOCs")
    parser.add_argument("roots", nargs="*", default=["."], help="roots to scan, e.g. C:/projects")
    parser.add_argument("--include-node-modules", action="store_true", help="also scan node_modules package files/payloads")
    parser.add_argument("--json", action="store_true", help="emit JSON")
    parser.add_argument(
        "--warn-package-names",
        action="store_true",
        help="also report non-critical affected-ecosystem package-name presence",
    )
    args = parser.parse_args()

    findings: list[Finding] = []
    scanned = 0
    for root_s in args.roots:
        root = Path(root_s).expanduser().resolve()
        files, _ = iter_files(root, args.include_node_modules)
        for path in files:
            scanned += 1
            file_findings = scan_file(path, read_text(path))
            if not args.warn_package_names:
                file_findings = [f for f in file_findings if f.severity != "info"]
            findings.extend(file_findings)

    critical = [f for f in findings if f.severity == "critical"]
    result = {"scanned_files": scanned, "critical_count": len(critical), "findings": [asdict(f) for f in findings]}
    if args.json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print(f"Scanned files: {scanned}")
        print(f"Critical findings: {len(critical)}")
        for f in findings:
            pkg = f" {f.package}@{f.version}" if f.package and f.version else f" {f.package}" if f.package else ""
            ev = f" evidence={f.evidence}" if f.evidence else ""
            print(f"[{f.severity}] {f.kind}{pkg} {f.path}{ev}")
    return 2 if critical else 0


if __name__ == "__main__":
    raise SystemExit(main())
