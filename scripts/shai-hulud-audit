#!/usr/bin/env python3
"""Deterministic Mini Shai-Hulud repository and install-root audit.

The script has two jobs:

1. Find known-bad package versions and payload indicators from the May 2026
   Mini Shai-Hulud npm/PyPI campaign. These are reported as ``critical`` and
   make the process exit with status 2.
2. Find package-manager hardening gaps that increase exposure to future
   install-time supply-chain attacks. These are reported as ``recommendation``
   and do not fail the process.

Design goals:

* stdlib-only so the file can be copied to other machines without bootstrapping
  dependencies;
* read-only scanning; no package manager install/import/build commands are run;
* deterministic matching against lockfiles, manifests, and known payload names;
* concise default output with JSON available for automation.

Typical usage:

    python scripts/shai-hulud-audit C:/projects
    python scripts/shai-hulud-audit C:/projects --json > audit.json
    python scripts/shai-hulud-audit C:/projects --no-hardening-recommendations

By default, the explicit roots are scanned and common global/user install roots
for npm, pnpm, Bun, and Python are added when they exist.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import site
import subprocess
import sys
from collections import defaultdict
from dataclasses import dataclass, asdict
from pathlib import Path

