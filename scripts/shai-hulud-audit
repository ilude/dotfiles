# Source: Aikido "Mini Shai-Hulud Is Back" affected package list, 2026-05-12,
# plus TanStack GHSA-g7cv-rxg3-hmpx and public PyPI reporting.
AFFECTED_NPM: dict[str, set[str]] = {}
AFFECTED_PYPI: dict[str, set[str]] = {
    "mistralai": {"2.4.6"},
    # Public reporting confirms guardrails-ai was affected but version lists have
    # varied by feed. Treat any exact IOC marker as critical; use package-name
    # presence as suspicious context rather than a version hit below.
}
SUSPICIOUS_PYPI_NAMES = {"guardrails-ai", "mistralai"}

