#!/usr/bin/env python3
"""Deterministic Mini Shai-Hulud repo/lockfile audit.

Scans repositories/trees for known compromised package versions and payload IOCs
from the May 2026 Mini Shai-Hulud npm/PyPI campaign. This is intentionally
stdlib-only so it can be copied to other machines.
"""
from __future__ import annotations

import argparse
import json
import os
import re
import sys
