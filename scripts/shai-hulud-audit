def run_command(args: list[str]) -> str | None:
    """Return stdout for a short discovery command, or ``None`` on failure.

    Only benign location-discovery commands such as ``npm root -g`` are used.
    A timeout keeps unavailable tools from making the audit feel hung.
    """
    try:
        proc = subprocess.run(args, capture_output=True, text=True, timeout=15, check=False)
    except (OSError, subprocess.SubprocessError):
        return None
    if proc.returncode != 0:
        return None
    return proc.stdout.strip()


def existing_paths(paths: list[str | Path]) -> list[Path]:
    """Resolve, de-duplicate, and keep only paths that exist."""
    out: list[Path] = []
    seen: set[str] = set()
    for raw in paths:
        if not raw:
            continue
        path = Path(raw).expanduser()
        try:
            resolved = path.resolve()
        except OSError:
            continue
        key = str(resolved).casefold() if os.name == "nt" else str(resolved)
        if key not in seen and resolved.exists():
            seen.add(key)
            out.append(resolved)
    return out


def default_scan_roots(user_roots: list[str]) -> list[Path]:
    """Return explicit roots plus discovered global/user package install roots.

    The function intentionally combines command-discovered paths with common
    platform fallback locations. This makes the script useful on fresh machines,
    CI runners, and developer workstations even when one package manager is not
    installed or not on PATH.
    """
    roots: list[str | Path] = [Path(r) for r in user_roots]

    npm_root = run_command(["npm", "root", "-g"])
    pnpm_root = run_command(["pnpm", "root", "-g"])
    bun_root = run_command(["bun", "pm", "g"])
    roots.extend([p for p in [npm_root, pnpm_root, bun_root] if p])

    try:
        roots.append(site.getusersitepackages())
    except (AttributeError, OSError):
        pass
    try:
        roots.extend(site.getsitepackages())
    except (AttributeError, OSError):
        pass

    local = os.environ.get("LOCALAPPDATA")
    appdata = os.environ.get("APPDATA")
    home = Path.home()
    roots.extend([
        home / ".npm-global" / "lib" / "node_modules",
        home / ".local" / "lib",
        home / ".local" / "pipx" / "venvs",
        home / ".local" / "share" / "pnpm" / "global",
        home / ".bun" / "install" / "global" / "node_modules",
    ])
    if local:
        # Windows python.org installs live under LOCALAPPDATA/Programs/Python.
        # Scan only site-packages leaves instead of the whole interpreter tree.
        python_programs = Path(local) / "Programs" / "Python"
        roots.extend([
            Path(local) / "pnpm" / "global",
            Path(local) / "pipx" / "venvs",
        ])
        if python_programs.exists():
            roots.extend(python_programs.glob("Python*/Lib/site-packages"))
    if appdata:
        roots.append(Path(appdata) / "npm" / "node_modules")

    return existing_paths(roots)


@dataclass
class Finding:
    """One audit result suitable for both human output and JSON serialization.

    ``severity`` is one of:
    * ``critical``: known compromised version or IOC; process exits 2;
    * ``recommendation``: hardening gap; actionable but non-failing;
    * ``info``: opt-in context from ``--warn-package-names``.
    """

    severity: str
    kind: str
    path: str
    package: str | None = None
    version: str | None = None
    evidence: str | None = None


